<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Studio Branding — La Traverse</title>
<link rel="icon" type="image/png" href="/images/logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,400;1,500;1,700&family=DM+Serif+Display:ital@0;1&family=Instrument+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700;800;900&family=Bebas+Neue&family=Poppins:wght@300;400;500;600;700;800;900&family=Oswald:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Montserrat:wght@300;400;500;600;700;800;900&family=Raleway:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/branding.css?v=<%= Date.now() %>">
<script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
</head>
<body>

<!-- TOP BAR -->
<header class="topbar">
  <div class="topbar__left">
    <a href="/admin" class="topbar__back" title="Retour admin">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 9H5m0 0l4-4m-4 4l4 4"/></svg>
    </a>
    <div class="topbar__brand">
      <span class="topbar__title">Studio</span>
      <span class="topbar__badge">Pro</span>
    </div>
  </div>

  <div class="topbar__center">
    <div class="topbar__history">
      <button class="topbar-btn" id="btn-undo" title="Annuler (Ctrl+Z)" disabled>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 7h7a4 4 0 010 8H7"/><path d="M6 4L3 7l3 3"/></svg>
      </button>
      <button class="topbar-btn" id="btn-redo" title="Refaire (Ctrl+Y)" disabled>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 7H6a4 4 0 000 8h3"/><path d="M10 4l3 3-3 3"/></svg>
      </button>
    </div>
    <div class="topbar__zoom">
      <button class="topbar-btn" id="btn-zoom-out" title="Zoom -">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="7" x2="11" y2="7"/></svg>
      </button>
      <span class="topbar__zoom-val" id="zoom-val">100%</span>
      <button class="topbar-btn" id="btn-zoom-in" title="Zoom +">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="3" x2="7" y2="11"/><line x1="3" y1="7" x2="11" y2="7"/></svg>
      </button>
      <button class="topbar-btn" id="btn-zoom-fit" title="Ajuster">Fit</button>
    </div>
  </div>

  <div class="topbar__right">
    <button class="topbar-btn" id="btn-grid" title="Grille">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="8" y1="2" x2="8" y2="14"/></svg>
    </button>
    <button class="btn btn--ghost" id="btn-reset">Reset</button>
    <button class="btn btn--primary" id="btn-export">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7.5 2v7m0 0L4.5 6m3 3l3-3M2 11v1.5a1 1 0 001 1h9a1 1 0 001-1V11"/></svg>
      Exporter
    </button>
  </div>
</header>

<main class="workspace">
  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <nav class="sidebar__tabs">
      <button class="tab active" data-tab="design" title="Design">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M2 6h12"/></svg>
        <span>Design</span>
      </button>
      <button class="tab" data-tab="text" title="Texte">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 3h8M8 3v10M5.5 13h5"/></svg>
        <span>Texte</span>
      </button>
      <button class="tab" data-tab="style" title="Style">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="5"/><path d="M8 3v1M8 12v1M3 8h1M12 8h1"/></svg>
        <span>Style</span>
      </button>
      <button class="tab" data-tab="media" title="Medias">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="12" height="10" rx="1"/><circle cx="6" cy="7" r="1.5"/><path d="M14 11l-3.5-3.5L6 12"/></svg>
        <span>Medias</span>
      </button>
    </nav>

    <!-- TAB: Design -->
    <div class="tab-content active" data-tab-content="design">
      <section class="panel">
        <h3 class="panel__title">Format</h3>
        <div class="format-grid">
          <button class="format-btn active" data-w="1080" data-h="1080" data-label="Post"><div class="format-btn__icon" style="width:26px;height:26px"></div><span>Post</span><small>1080x1080</small></button>
          <button class="format-btn" data-w="1080" data-h="1920" data-label="Story"><div class="format-btn__icon" style="width:18px;height:32px"></div><span>Story</span><small>1080x1920</small></button>
          <button class="format-btn" data-w="1200" data-h="628" data-label="Banniere"><div class="format-btn__icon" style="width:34px;height:18px"></div><span>Banniere</span><small>1200x628</small></button>
          <button class="format-btn" data-w="1920" data-h="1080" data-label="Cover"><div class="format-btn__icon" style="width:34px;height:19px"></div><span>Cover</span><small>1920x1080</small></button>
          <button class="format-btn" data-w="1080" data-h="1350" data-label="Portrait"><div class="format-btn__icon" style="width:22px;height:28px"></div><span>Portrait</span><small>1080x1350</small></button>
          <button class="format-btn" data-w="1200" data-h="900" data-label="Blog"><div class="format-btn__icon" style="width:30px;height:22px"></div><span>Blog</span><small>1200x900</small></button>
          <button class="format-btn" data-w="1500" data-h="500" data-label="Twitter"><div class="format-btn__icon" style="width:40px;height:13px"></div><span>Twitter</span><small>1500x500</small></button>
          <button class="format-btn" data-w="1080" data-h="566" data-label="LinkedIn"><div class="format-btn__icon" style="width:34px;height:18px"></div><span>LinkedIn</span><small>1080x566</small></button>
        </div>
      </section>

      <section class="panel">
        <h3 class="panel__title">Templates</h3>
        <div class="template-grid">
          <button class="template-btn active" data-template="minimal"><div class="tmpl tmpl--minimal"></div><span>Minimal</span></button>
          <button class="template-btn" data-template="bold"><div class="tmpl tmpl--bold"></div><span>Bold</span></button>
          <button class="template-btn" data-template="gradient"><div class="tmpl tmpl--gradient"></div><span>Gradient</span></button>
          <button class="template-btn" data-template="split"><div class="tmpl tmpl--split"></div><span>Split</span></button>
          <button class="template-btn" data-template="editorial"><div class="tmpl tmpl--editorial"></div><span>Editorial</span></button>
          <button class="template-btn" data-template="glass"><div class="tmpl tmpl--glass"></div><span>Glass</span></button>
          <button class="template-btn" data-template="neon"><div class="tmpl tmpl--neon"></div><span>Neon</span></button>
          <button class="template-btn" data-template="promo"><div class="tmpl tmpl--promo"></div><span>Promo</span></button>
          <button class="template-btn" data-template="quote"><div class="tmpl tmpl--quote"></div><span>Citation</span></button>
          <button class="template-btn" data-template="duotone"><div class="tmpl tmpl--duotone"></div><span>Duotone</span></button>
          <button class="template-btn" data-template="geometric"><div class="tmpl tmpl--geometric"></div><span>Geometric</span></button>
          <button class="template-btn" data-template="typewriter"><div class="tmpl tmpl--typewriter"></div><span>Typewriter</span></button>
        </div>
      </section>
    </div>

    <!-- TAB: Texte -->
    <div class="tab-content" data-tab-content="text">
      <section class="panel">
        <h3 class="panel__title">Contenu</h3>
        <div class="field">
          <label>Titre principal</label>
          <input type="text" id="input-headline" value="Studio digital" placeholder="Titre...">
        </div>
        <div class="field">
          <label>Sous-titre</label>
          <input type="text" id="input-subline" value="Marseille" placeholder="Sous-titre...">
        </div>
        <div class="field">
          <label>Corps de texte</label>
          <textarea id="input-body" rows="3" placeholder="Description...">Sites, apps et outils sur-mesure pour artisans, commercants et independants.</textarea>
        </div>
        <div class="field">
          <label>CTA / Bas de page</label>
          <input type="text" id="input-cta" value="latraverse.studio" placeholder="CTA ou URL...">
        </div>
      </section>

      <section class="panel">
        <h3 class="panel__title">Typographie — Titre</h3>
        <div class="field">
          <label>Police</label>
          <select id="typo-headline-font" class="select-input">
            <option value="'Playfair Display', serif" selected>Playfair Display</option>
            <option value="'DM Serif Display', serif">DM Serif Display</option>
            <option value="'Bebas Neue', sans-serif">Bebas Neue</option>
            <option value="'Montserrat', sans-serif">Montserrat</option>
            <option value="'Poppins', sans-serif">Poppins</option>
            <option value="'Oswald', sans-serif">Oswald</option>
            <option value="'Inter', sans-serif">Inter</option>
            <option value="'Raleway', sans-serif">Raleway</option>
            <option value="'Lora', serif">Lora</option>
            <option value="'Instrument Sans', sans-serif">Instrument Sans</option>
            <option value="'Libre Baskerville', serif">Libre Baskerville</option>
            <option value="'Space Mono', monospace">Space Mono</option>
          </select>
        </div>
        <div class="field-row">
          <div class="field field--half">
            <label>Taille</label>
            <div class="range-with-val">
              <input type="range" id="typo-headline-size" min="16" max="120" value="48">
              <span class="range-val" id="typo-headline-size-val">48</span>
            </div>
          </div>
          <div class="field field--half">
            <label>Graisse</label>
            <select id="typo-headline-weight" class="select-input">
              <option value="300">Light</option>
              <option value="400">Regular</option>
              <option value="500">Medium</option>
              <option value="600">Semi Bold</option>
              <option value="700" selected>Bold</option>
              <option value="800">Extra Bold</option>
              <option value="900">Black</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label>Alignement</label>
          <div class="align-btns">
            <button class="align-btn active" data-align="left" data-target="headline" title="Gauche">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="3" x2="13" y2="3"/><line x1="1" y1="7" x2="9" y2="7"/><line x1="1" y1="11" x2="11" y2="11"/></svg>
            </button>
            <button class="align-btn" data-align="center" data-target="headline" title="Centre">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="3" x2="13" y2="3"/><line x1="3" y1="7" x2="11" y2="7"/><line x1="2" y1="11" x2="12" y2="11"/></svg>
            </button>
            <button class="align-btn" data-align="right" data-target="headline" title="Droite">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="3" x2="13" y2="3"/><line x1="5" y1="7" x2="13" y2="7"/><line x1="3" y1="11" x2="13" y2="11"/></svg>
            </button>
          </div>
        </div>
        <div class="field">
          <label>Casse</label>
          <div class="case-btns">
            <button class="case-btn active" data-case="none" title="Normal">Aa</button>
            <button class="case-btn" data-case="uppercase" title="Majuscules">AA</button>
            <button class="case-btn" data-case="lowercase" title="Minuscules">aa</button>
          </div>
        </div>
        <div class="field-row">
          <div class="field field--half">
            <label>Interligne</label>
            <div class="range-with-val">
              <input type="range" id="typo-headline-lh" min="80" max="160" value="110">
              <span class="range-val" id="typo-headline-lh-val">1.1</span>
            </div>
          </div>
          <div class="field field--half">
            <label>Espacement</label>
            <div class="range-with-val">
              <input type="range" id="typo-headline-ls" min="-5" max="20" value="0">
              <span class="range-val" id="typo-headline-ls-val">0</span>
            </div>
          </div>
        </div>
      </section>

      <section class="panel">
        <h3 class="panel__title">Typographie — Corps</h3>
        <div class="field">
          <label>Police</label>
          <select id="typo-body-font" class="select-input">
            <option value="'Libre Baskerville', serif" selected>Libre Baskerville</option>
            <option value="'Inter', sans-serif">Inter</option>
            <option value="'Poppins', sans-serif">Poppins</option>
            <option value="'Instrument Sans', sans-serif">Instrument Sans</option>
            <option value="'Lora', serif">Lora</option>
            <option value="'Raleway', sans-serif">Raleway</option>
            <option value="'Space Mono', monospace">Space Mono</option>
          </select>
        </div>
        <div class="field-row">
          <div class="field field--half">
            <label>Taille</label>
            <div class="range-with-val">
              <input type="range" id="typo-body-size" min="10" max="32" value="15">
              <span class="range-val" id="typo-body-size-val">15</span>
            </div>
          </div>
          <div class="field field--half">
            <label>Graisse</label>
            <select id="typo-body-weight" class="select-input">
              <option value="300">Light</option>
              <option value="400" selected>Regular</option>
              <option value="500">Medium</option>
              <option value="600">Semi Bold</option>
              <option value="700">Bold</option>
            </select>
          </div>
        </div>
      </section>
    </div>

    <!-- TAB: Style -->
    <div class="tab-content" data-tab-content="style">
      <section class="panel">
        <h3 class="panel__title">Couleurs</h3>
        <div class="color-row">
          <label>Fond</label>
          <div class="color-presets" data-target="bg">
            <button class="color-dot active" style="background:#1a1714" data-color="#1a1714"></button>
            <button class="color-dot" style="background:#0a0a0a" data-color="#0a0a0a"></button>
            <button class="color-dot" style="background:#0c1220" data-color="#0c1220"></button>
            <button class="color-dot" style="background:#fafaf8" data-color="#fafaf8"></button>
            <button class="color-dot" style="background:#f5f0e8" data-color="#f5f0e8"></button>
            <button class="color-dot" style="background:#c4622a" data-color="#c4622a"></button>
            <button class="color-dot" style="background:#1a2332" data-color="#1a2332"></button>
            <button class="color-dot" style="background:#2d1b2e" data-color="#2d1b2e"></button>
          </div>
          <input type="color" id="color-bg" value="#1a1714" class="color-input">
        </div>
        <div class="color-row">
          <label>Texte</label>
          <div class="color-presets" data-target="text">
            <button class="color-dot active" style="background:#f0e8dc" data-color="#f0e8dc"></button>
            <button class="color-dot" style="background:#ffffff" data-color="#ffffff"></button>
            <button class="color-dot" style="background:#1a1a1a" data-color="#1a1a1a"></button>
            <button class="color-dot" style="background:#c4622a" data-color="#c4622a"></button>
            <button class="color-dot" style="background:#e8d5c0" data-color="#e8d5c0"></button>
          </div>
          <input type="color" id="color-text" value="#f0e8dc" class="color-input">
        </div>
        <div class="color-row">
          <label>Accent</label>
          <div class="color-presets" data-target="accent">
            <button class="color-dot active" style="background:#c4622a" data-color="#c4622a"></button>
            <button class="color-dot" style="background:#d4722e" data-color="#d4722e"></button>
            <button class="color-dot" style="background:#e8a87c" data-color="#e8a87c"></button>
            <button class="color-dot" style="background:#5a8f7b" data-color="#5a8f7b"></button>
            <button class="color-dot" style="background:#4a6fa5" data-color="#4a6fa5"></button>
            <button class="color-dot" style="background:#a85050" data-color="#a85050"></button>
            <button class="color-dot" style="background:#8b6fb0" data-color="#8b6fb0"></button>
            <button class="color-dot" style="background:#c49a2a" data-color="#c49a2a"></button>
          </div>
          <input type="color" id="color-accent" value="#c4622a" class="color-input">
        </div>
      </section>

      <section class="panel">
        <h3 class="panel__title">Fond gradient</h3>
        <div class="field field--check">
          <input type="checkbox" id="opt-gradient">
          <label for="opt-gradient">Activer le gradient</label>
        </div>
        <div class="gradient-controls" id="gradient-controls" style="display:none">
          <div class="field">
            <label>Angle <span id="gradient-angle-val">135</span>deg</label>
            <input type="range" id="gradient-angle" min="0" max="360" value="135">
          </div>
          <div class="color-row">
            <label>Debut</label>
            <input type="color" id="gradient-start" value="#c4622a" class="color-input color-input--lg">
          </div>
          <div class="color-row">
            <label>Fin</label>
            <input type="color" id="gradient-end" value="#1a1714" class="color-input color-input--lg">
          </div>
          <div class="gradient-presets">
            <button class="gradient-preset" data-start="#c4622a" data-end="#1a1714" data-angle="135" style="background:linear-gradient(135deg,#c4622a,#1a1714)"></button>
            <button class="gradient-preset" data-start="#667eea" data-end="#764ba2" data-angle="135" style="background:linear-gradient(135deg,#667eea,#764ba2)"></button>
            <button class="gradient-preset" data-start="#f093fb" data-end="#f5576c" data-angle="135" style="background:linear-gradient(135deg,#f093fb,#f5576c)"></button>
            <button class="gradient-preset" data-start="#4facfe" data-end="#00f2fe" data-angle="135" style="background:linear-gradient(135deg,#4facfe,#00f2fe)"></button>
            <button class="gradient-preset" data-start="#43e97b" data-end="#38f9d7" data-angle="135" style="background:linear-gradient(135deg,#43e97b,#38f9d7)"></button>
            <button class="gradient-preset" data-start="#fa709a" data-end="#fee140" data-angle="135" style="background:linear-gradient(135deg,#fa709a,#fee140)"></button>
            <button class="gradient-preset" data-start="#a18cd1" data-end="#fbc2eb" data-angle="135" style="background:linear-gradient(135deg,#a18cd1,#fbc2eb)"></button>
            <button class="gradient-preset" data-start="#0c0c0c" data-end="#313131" data-angle="180" style="background:linear-gradient(180deg,#0c0c0c,#313131)"></button>
          </div>
        </div>
      </section>

      <section class="panel">
        <h3 class="panel__title">Effets texte</h3>
        <div class="field">
          <label>Ombre du titre <span id="fx-shadow-val">0</span></label>
          <input type="range" id="fx-shadow" min="0" max="30" value="0">
        </div>
        <div class="field">
          <label>Glow accent <span id="fx-glow-val">0</span></label>
          <input type="range" id="fx-glow" min="0" max="40" value="0">
        </div>
        <div class="field field--check">
          <input type="checkbox" id="fx-outline">
          <label for="fx-outline">Contour texte (stroke)</label>
        </div>
      </section>

      <section class="panel">
        <h3 class="panel__title">Options</h3>
        <div class="field field--check">
          <input type="checkbox" id="opt-logo" checked>
          <label for="opt-logo">Logo La Traverse</label>
        </div>
        <div class="field field--check">
          <input type="checkbox" id="opt-border" checked>
          <label for="opt-border">Bordure accent</label>
        </div>
        <div class="field field--check">
          <input type="checkbox" id="opt-grain">
          <label for="opt-grain">Texture grain</label>
        </div>
        <div class="field field--check">
          <input type="checkbox" id="opt-vignette">
          <label for="opt-vignette">Vignette</label>
        </div>
      </section>
    </div>

    <!-- TAB: Medias -->
    <div class="tab-content" data-tab-content="media">
      <section class="panel">
        <h3 class="panel__title">Image de fond</h3>
        <div class="upload-zone" id="upload-zone-bg">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          <span>Glisser ou cliquer</span>
          <input type="file" id="input-bgimage" accept="image/*" class="upload-zone__input">
        </div>
        <button class="btn btn--ghost btn--sm btn--full" id="btn-clear-bg" style="display:none">Supprimer l'image de fond</button>
        <div id="bg-image-controls" style="display:none">
          <div class="field">
            <label>Opacite overlay <span id="opacity-val">70</span>%</label>
            <input type="range" id="input-opacity" min="0" max="100" value="70">
          </div>
          <div class="field">
            <label>Flou de fond <span id="blur-val">0</span>px</label>
            <input type="range" id="input-blur" min="0" max="20" value="0">
          </div>
        </div>
      </section>

      <section class="panel">
        <h3 class="panel__title">Galerie d'images</h3>
        <div class="field">
          <input type="file" id="input-add-image" accept="image/*" class="file-input">
        </div>
        <div class="image-gallery" id="image-gallery"></div>
        <p class="gallery-hint" id="gallery-hint">Uploadez des images pour les utiliser</p>
      </section>

      <section class="panel">
        <h3 class="panel__title">Generation IA</h3>
        <div class="field">
          <label>Prompt</label>
          <textarea id="ai-prompt" rows="3" placeholder="Decrivez l'image souhaitee..."></textarea>
        </div>
        <button class="btn--ai" id="btn-generate-ai">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1v3M8 12v3M1 8h3M12 8h3M3 3l2 2M11 11l2 2M3 13l2-2M11 5l2-2"/></svg>
          <span class="btn-ai-text">Generer l'image</span>
        </button>
        <div class="ai-error" id="ai-error" style="display:none"></div>
        <div class="ai-result" id="ai-result" style="display:none">
          <img id="ai-result-img" src="" alt="Image generee">
          <div class="ai-result__actions">
            <button class="btn btn--primary btn--sm" id="btn-ai-bg">Utiliser en fond</button>
            <button class="btn btn--ghost btn--sm" id="btn-ai-save">Sauvegarder</button>
          </div>
        </div>
      </section>
    </div>
  </aside>

  <!-- CANVAS AREA -->
  <div class="canvas-area" id="canvas-area">
    <div class="canvas-grid" id="canvas-grid"></div>
    <div class="canvas-wrapper" id="canvas-wrapper">
      <div class="canvas" id="canvas" data-template="minimal">
        <div class="canvas__grain" id="canvas-grain"></div>
        <div class="canvas__border" id="canvas-border"></div>
        <div class="canvas__bgimage" id="canvas-bgimage"></div>
        <div class="canvas__vignette" id="canvas-vignette"></div>
        <div class="canvas__decorations" id="canvas-decorations"></div>
        <div class="canvas__glass-panel" id="canvas-glass-panel"></div>
        <div class="canvas__content">
          <div class="canvas__logo" id="canvas-logo">
            <svg viewBox="0 0 40 40" width="28" height="28" fill="none">
              <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 20h16M20 12v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>La Traverse</span>
          </div>
          <div class="canvas__headline" id="canvas-headline" contenteditable="true" spellcheck="false">Studio digital</div>
          <div class="canvas__subline" id="canvas-subline" contenteditable="true" spellcheck="false">Marseille</div>
          <div class="canvas__body" id="canvas-body" contenteditable="true" spellcheck="false">Sites, apps et outils sur-mesure pour artisans, commercants et independants.</div>
          <div class="canvas__cta" id="canvas-cta" contenteditable="true" spellcheck="false">latraverse.studio</div>
        </div>
      </div>
    </div>
    <div class="canvas-info">
      <span id="info-format">Post — 1080 x 1080</span>
      <span class="canvas-info__sep">|</span>
      <span id="info-template">Minimal</span>
      <span class="canvas-info__sep">|</span>
      <span id="info-shortcuts">Ctrl+Z Annuler &middot; Ctrl+E Exporter</span>
    </div>
  </div>
</main>

<!-- Export overlay -->
<div class="export-overlay" id="export-overlay">
  <div class="export-overlay__inner">
    <div class="spinner"></div>
    <p>Export en cours...</p>
  </div>
</div>

<script src="/js/branding.js?v=<%= Date.now() %>"></script>
</body>
</html>
