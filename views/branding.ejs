    <div class="spinner"></div>
    <p id="export-overlay-text">Export en cours...</p>
    <div class="export-progress" id="export-progress" style="display:none">
      <div class="export-progress__bar" id="export-progress-bar"></div>
    </div>
  </div>
</div>

<!-- Keyboard Shortcuts Modal -->
<div class="shortcuts-overlay" id="shortcuts-overlay">
  <div class="shortcuts-modal">
    <div class="shortcuts-modal__header">
      <h3>Raccourcis clavier</h3>
      <button class="shortcuts-modal__close" id="shortcuts-close">&times;</button>
    </div>
    <div class="shortcuts-modal__body">
      <div class="shortcuts-modal__group">
        <div class="shortcuts-modal__title">General</div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>Z</kbd></span><span>Annuler</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>Y</kbd></span><span>Refaire</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>E</kbd></span><span>Exporter</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Esc</kbd></span><span>Fermer le panneau</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>?</kbd></span><span>Raccourcis clavier</span></div>
      </div>
      <div class="shortcuts-modal__group">
        <div class="shortcuts-modal__title">Stickers</div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>D</kbd></span><span>Dupliquer</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Suppr</kbd></span><span>Supprimer</span></div>
      </div>
      <div class="shortcuts-modal__group">
        <div class="shortcuts-modal__title">Canvas</div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>Scroll</kbd></span><span>Zoom</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>+</kbd></span><span>Zoom avant</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>-</kbd></span><span>Zoom arriere</span></div>
        <div class="shortcut-row"><span class="shortcut-keys"><kbd>Ctrl</kbd><kbd>0</kbd></span><span>Reinitialiser zoom</span></div>
      </div>
    </div>
  </div>
</div>

<!-- AI Generator Modal -->
<div class="ai-modal-overlay" id="ai-modal-overlay">
  <div class="ai-modal">
    <div class="ai-modal__header">
      <div class="ai-modal__title-row">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1v3M8 12v3M1 8h3M12 8h3M3 3l2 2M11 11l2 2M3 13l2-2M11 5l2-2"/></svg>
        <h3>Generateur IA</h3>
      </div>
      <div class="ai-modal__tabs">
        <button class="ai-tab active" data-ai-tab="prompt">Prompt libre</button>
        <button class="ai-tab" data-ai-tab="url">Depuis un site</button>
      </div>
      <button class="ai-modal__close" id="ai-modal-close">&times;</button>
    </div>

    <!-- Tab: Prompt libre -->
    <div class="ai-modal__body ai-tab-content active" data-ai-tab-content="prompt">
      <p class="ai-modal__desc">Decris ta pub en quelques mots. L'IA genere tout : texte, style, template et mise en page.</p>
      <div class="ai-modal__field">
        <textarea id="ai-gen-prompt" rows="3" placeholder="Ex: Promo ete -30% pour un restaurant italien a Marseille, ambiance chaleureuse et gourmande..."></textarea>
        <button class="ai-modal__improve" id="btn-improve-prompt" title="Ameliorer le prompt avec l'IA">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1v3M8 10v3M1 7h3M10 7h3M3.5 3.5l1.5 1.5M9 9l1.5 1.5M3.5 10.5l1.5-1.5M9 5l1.5-1.5"/></svg>
          <span>Booster le prompt</span>
        </button>
      </div>
      <div class="ai-modal__error" id="ai-gen-error" style="display:none"></div>
      <button class="ai-modal__generate" id="btn-ai-generate-all">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1v3M8 12v3M1 8h3M12 8h3M3 3l2 2M11 11l2 2M3 13l2-2M11 5l2-2"/></svg>
        <span class="ai-gen-text">Generer le design</span>
      </button>
    </div>

    <!-- Tab: Depuis un site -->
    <div class="ai-modal__body ai-tab-content" data-ai-tab-content="url">
      <p class="ai-modal__desc">Colle l'URL d'un site web. L'IA l'analyse et propose des idees de campagnes visuelles adaptees.</p>
      <div class="ai-url__input-row">
        <div class="ai-url__field">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6.5 11.5a4 4 0 01-1-7.9M9.5 4.5a4 4 0 011 7.9M6 8h4"/></svg>
          <input type="url" id="ai-url-input" placeholder="https://example.com" spellcheck="false">
        </div>
        <button class="ai-url__analyze" id="btn-scrape-url">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 12l4-4m0 0l4 4m-4-4v9M21 3H3"/><circle cx="12" cy="8" r="3"/></svg>
          <span class="ai-url__analyze-text">Analyser</span>
        </button>
      </div>
      <div class="ai-url__error" id="ai-url-error" style="display:none"></div>

      <!-- Business info (shown after scrape) -->
      <div class="ai-url__business" id="ai-url-business" style="display:none">
        <div class="ai-url__business-info">
          <span class="ai-url__business-name" id="ai-biz-name"></span>
          <span class="ai-url__business-badge" id="ai-biz-industry"></span>
          <span class="ai-url__business-vibe" id="ai-biz-vibe"></span>
        </div>
      </div>

      <!-- Ideas grid (shown after scrape) -->
      <div class="ai-ideas-grid" id="ai-ideas-grid" style="display:none"></div>
    </div>
  </div>
</div>

<!-- Template preview tooltip -->
<div class="tmpl-preview" id="tmpl-preview">
  <div class="tmpl-preview__thumb" id="tmpl-preview-thumb"></div>
  <div class="tmpl-preview__label" id="tmpl-preview-label"></div>
</div>

<!-- CREATIVE AGENT -->
<button id="agent-btn" class="agent-fab" title="Agent Créatif (vocal)"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg><span class="agent-fab__pulse"></span></button>
<div id="agent-panel" class="agent-panel">
  <div class="agent-panel__header">
    <div class="agent-panel__title"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" x2="9.01" y1="9" y2="9"/><line x1="15" x2="15.01" y1="9" y2="9"/></svg> Agent Créatif</div>
    <div class="agent-panel__actions"><span id="agent-status" class="agent-panel__status"></span><button id="agent-clear" class="agent-panel__btn" title="Effacer"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button><button id="agent-close" class="agent-panel__btn" title="Fermer"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg></button></div>
  </div>
  <div id="agent-messages" class="agent-panel__messages"></div>
  <div class="agent-panel__input">
    <button id="agent-mic" class="agent-input__mic" title="Parler"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg></button>
    <input type="text" id="agent-input" class="agent-input__field" placeholder="Dis quelque chose..." autocomplete="off">
    <button id="agent-send" class="agent-input__send" title="Envoyer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></button>
  </div>
</div>

<script src="/js/branding.js?v=<%= Date.now() %>"></script>
<script src="/js/realtime-client.js?v=<%= Date.now() %>"></script>
<script src="/js/branding-agent.js?v=<%= Date.now() %>"></script>
</body>
</html>
