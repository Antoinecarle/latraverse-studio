<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Studio Branding — La Traverse</title>
<link rel="icon" type="image/png" href="/images/logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,400;1,500;1,700&family=DM+Serif+Display:ital@0;1&family=Instrument+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700;800;900&family=Bebas+Neue&family=Poppins:wght@300;400;500;600;700;800;900&family=Oswald:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Montserrat:wght@300;400;500;600;700;800;900&family=Raleway:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/branding.css?v=<%= Date.now() %>">
<script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gif.js@0.2.0/dist/gif.js"></script>
</head>
<body>

<!-- TOP BAR -->
<header class="topbar">
  <div class="topbar__left">
    <a href="/admin" class="topbar__back" title="Retour admin">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 9H5m0 0l4-4m-4 4l4 4"/></svg>
    </a>
    <div class="topbar__brand">
      <span class="topbar__title">Studio</span>
      <span class="topbar__badge">Pro</span>
    </div>
    <div class="topbar__pub-selector">
      <div class="pub-current" id="pub-current">
        <input type="text" id="pub-name" class="pub-name-input" value="Sans titre" placeholder="Nom de la pub..." spellcheck="false">
        <button class="pub-toggle" id="pub-toggle" title="Mes pubs">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 5l4 4 4-4"/></svg>
        </button>
      </div>
      <span class="save-indicator" id="save-indicator"></span>
      <div class="pub-dropdown" id="pub-dropdown">
        <div class="pub-dropdown__header">
          <span>Mes pubs</span>
          <button class="pub-dropdown__new" id="btn-new-pub" title="Nouvelle pub">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="7" y1="2" x2="7" y2="12"/><line x1="2" y1="7" x2="12" y2="7"/></svg>
            Nouvelle
          </button>
        </div>
        <div class="pub-dropdown__list" id="pub-list"></div>
        <div class="pub-dropdown__empty" id="pub-empty">Aucune pub sauvegardee</div>
      </div>
    </div>
  </div>

  <div class="topbar__center">
    <div class="topbar__history">
      <button class="topbar-btn" id="btn-undo" title="Annuler (Ctrl+Z)" disabled>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 7h7a4 4 0 010 8H7"/><path d="M6 4L3 7l3 3"/></svg>
      </button>
      <button class="topbar-btn" id="btn-redo" title="Refaire (Ctrl+Y)" disabled>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 7H6a4 4 0 000 8h3"/><path d="M10 4l3 3-3 3"/></svg>
      </button>
    </div>
    <div class="topbar__sep"></div>
    <div class="topbar__zoom">
      <button class="topbar-btn" id="btn-zoom-out" title="Zoom -">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="7" x2="11" y2="7"/></svg>
      </button>
      <span class="topbar__zoom-val" id="zoom-val">100%</span>
      <button class="topbar-btn" id="btn-zoom-in" title="Zoom +">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="3" x2="7" y2="11"/><line x1="3" y1="7" x2="11" y2="7"/></svg>
      </button>
      <button class="topbar-btn" id="btn-zoom-fit" title="Ajuster">Fit</button>
    </div>
  </div>

  <div class="topbar__right">
    <button class="topbar-btn" id="btn-grid" title="Grille">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="8" y1="2" x2="8" y2="14"/></svg>
    </button>
    <button class="btn btn--ai-topbar" id="btn-open-ai" title="Generateur IA">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7.5 1v2.5M7.5 11v2.5M1 7.5h2.5M11 7.5h2.5M3 3l1.5 1.5M10 10l1.5 1.5M3 12l1.5-1.5M10 5l1.5-1.5"/></svg>
      IA
    </button>
    <button class="topbar-btn" id="btn-layers" title="Calques">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M8 1L1 5l7 4 7-4-7-4z"/><path d="M1 8l7 4 7-4"/><path d="M1 11l7 4 7-4"/></svg>
    </button>
    <button class="btn btn--ghost" id="btn-reset">Reset</button>
    <div class="export-wrap" id="export-wrap">
      <button class="btn btn--primary" id="btn-export-toggle">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7.5 2v7m0 0L4.5 6m3 3l3-3M2 11v1.5a1 1 0 001 1h9a1 1 0 001-1V11"/></svg>
        Exporter
      </button>
      <div class="export-dropdown" id="export-dropdown" style="display:none">
        <div class="export-dropdown__row">
          <span class="export-dropdown__label">Format</span>
          <div class="export-dropdown__toggle" id="export-format-toggle">
            <button class="export-dropdown__opt active" data-val="png">PNG</button>
            <button class="export-dropdown__opt" data-val="jpeg">JPEG</button>
            <button class="export-dropdown__opt" data-val="gif">GIF</button>
            <button class="export-dropdown__opt" data-val="webm">Video</button>
          </div>
        </div>
        <div class="export-dropdown__row" id="export-quality-row" style="display:none">
          <span class="export-dropdown__label">Qualite <span id="export-quality-val">92</span>%</span>
          <input type="range" id="export-quality" min="50" max="100" value="92" class="export-dropdown__range">
        </div>
        <div class="export-dropdown__row" id="export-duration-row" style="display:none">
          <span class="export-dropdown__label">Duree <span id="export-duration-val">3</span>s</span>
          <input type="range" id="export-duration" min="2" max="6" value="3" step="1" class="export-dropdown__range">
        </div>
        <div class="export-dropdown__row" id="export-fps-row" style="display:none">
          <span class="export-dropdown__label">FPS <span id="export-fps-val">10</span></span>
          <input type="range" id="export-fps" min="5" max="15" value="10" step="1" class="export-dropdown__range">
        </div>
        <div class="export-dropdown__row">
          <span class="export-dropdown__label">Resolution</span>
          <div class="export-dropdown__toggle" id="export-scale-toggle">
            <button class="export-dropdown__opt active" data-val="1">1x</button>
            <button class="export-dropdown__opt" data-val="2">2x</button>
          </div>
        </div>
        <div class="export-dropdown__row export-dropdown__row--info">
          <span id="export-size-info">1080 x 1080 px</span>
        </div>
        <div class="export-dropdown__actions">
        <button class="btn btn--primary btn--full" id="btn-export">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 2v6m0 0L4.5 5.5M7 8l2.5-2.5M2 10v1a1 1 0 001 1h8a1 1 0 001-1v-1"/></svg>
          Telecharger
        </button>
        <button class="btn btn--ghost btn--full" id="btn-copy-clipboard">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="8" height="8" rx="1.5"/><path d="M6 3V2a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-1"/></svg>
          Copier dans le presse-papier
        </button>
        </div>
      </div>
    </div>
  </div>
</header>

<main class="workspace">
  <!-- ICON RAIL -->
  <nav class="rail" id="studio-rail">
    <button class="rail__btn active" data-tab="design" title="Design">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="14" height="14" rx="2.5"/><path d="M2 7h14"/></svg>
    </button>
    <button class="rail__btn" data-tab="text" title="Texte">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 3h10M9 3v12M6 15h6"/></svg>
    </button>
    <button class="rail__btn" data-tab="style" title="Style">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="9" r="6"/><path d="M9 3v1.5M9 13.5V15M3 9h1.5M13.5 9H15"/></svg>
    </button>
    <button class="rail__btn" data-tab="stickers" title="Stickers">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h5v5H3zM10 3h5v5H10zM3 10h5v5H3z"/><circle cx="12.5" cy="12.5" r="2.5"/></svg>
    </button>
    <button class="rail__btn" data-tab="media" title="Medias">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="14" height="12" rx="1.5"/><circle cx="7" cy="8" r="1.5"/><path d="M16 13l-4-4L7 14"/></svg>
    </button>
    <button class="rail__btn" data-tab="animations" title="Animations SVG">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 9a7 7 0 0114 0"/><path d="M5 9a4 4 0 018 0"/><circle cx="9" cy="9" r="1.5" fill="currentColor"/><path d="M9 12v4M7 14l2 2 2-2"/></svg>
    </button>
  </nav>

  <!-- SLIDE PANEL -->
  <aside class="panel-drawer open" id="sidebar">
    <div class="panel-drawer__head">
      <h3 class="panel-drawer__title" id="panel-title">Design</h3>
      <button class="panel-drawer__close" id="panel-close" title="Fermer">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 3L3 11M3 3l8 8"/></svg>
      </button>
    </div>
    <div class="panel-drawer__scroll">

    <!-- TAB: Design -->
    <div class="tab-content active" data-tab-content="design">
      <section class="panel panel--collapsible">
        <h3 class="panel__title panel__title--toggle" data-collapsed="true">Format <svg class="panel__chevron" width="10" height="6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 1l4 4 4-4"/></svg></h3>
        <div class="panel__body">
        <div class="format-grid">
          <button class="format-btn active" data-w="1080" data-h="1080" data-label="Post"><div class="format-btn__icon" style="width:26px;height:26px"></div><span>Post</span><small>1080x1080</small></button>
          <button class="format-btn" data-w="1080" data-h="1920" data-label="Story"><div class="format-btn__icon" style="width:18px;height:32px"></div><span>Story</span><small>1080x1920</small></button>
          <button class="format-btn" data-w="1200" data-h="628" data-label="Banniere"><div class="format-btn__icon" style="width:34px;height:18px"></div><span>Banniere</span><small>1200x628</small></button>
          <button class="format-btn" data-w="1920" data-h="1080" data-label="Cover"><div class="format-btn__icon" style="width:34px;height:19px"></div><span>Cover</span><small>1920x1080</small></button>
          <button class="format-btn" data-w="1080" data-h="1350" data-label="Portrait"><div class="format-btn__icon" style="width:22px;height:28px"></div><span>Portrait</span><small>1080x1350</small></button>
          <button class="format-btn" data-w="1200" data-h="900" data-label="Blog"><div class="format-btn__icon" style="width:30px;height:22px"></div><span>Blog</span><small>1200x900</small></button>
          <button class="format-btn" data-w="1500" data-h="500" data-label="Twitter"><div class="format-btn__icon" style="width:40px;height:13px"></div><span>Twitter</span><small>1500x500</small></button>
          <button class="format-btn" data-w="1080" data-h="566" data-label="LinkedIn"><div class="format-btn__icon" style="width:34px;height:18px"></div><span>LinkedIn</span><small>1080x566</small></button>
        </div>
        </div>
      </section>

      <section class="panel panel--collapsible">
        <h3 class="panel__title panel__title--toggle" data-collapsed="true">Style Packs <svg class="panel__chevron" width="10" height="6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 1l4 4 4-4"/></svg></h3>
        <div class="panel__body">
        <div class="style-packs-grid">
          <button class="style-pack-btn" data-pack="traverse">
            <div class="style-pack-swatch__bg" style="background:#1a1714"><div class="style-pack-swatch__accent" style="background:#c4622a"></div><div class="style-pack-swatch__accent2" style="background:#e8a87c"></div></div>
            <span>Traverse</span>
          </button>
          <button class="style-pack-btn" data-pack="tech">
            <div class="style-pack-swatch__bg" style="background:#0e0b1a"><div class="style-pack-swatch__accent" style="background:#8b5cf6"></div><div class="style-pack-swatch__accent2" style="background:#a78bfa"></div></div>
            <span>Tech</span>
          </button>
          <button class="style-pack-btn" data-pack="ocean">
            <div class="style-pack-swatch__bg" style="background:#0a1628"><div class="style-pack-swatch__accent" style="background:#38bdf8"></div><div class="style-pack-swatch__accent2" style="background:#7dd3fc"></div></div>
            <span>Ocean</span>
          </button>
          <button class="style-pack-btn" data-pack="neonpop">
            <div class="style-pack-swatch__bg" style="background:#000000"><div class="style-pack-swatch__accent" style="background:#22d3ee"></div><div class="style-pack-swatch__accent2" style="background:#f43f5e"></div></div>
            <span>Neon Pop</span>
          </button>
          <button class="style-pack-btn" data-pack="light">
            <div class="style-pack-swatch__bg" style="background:#fafaf8;border-color:rgba(0,0,0,0.1)"><div class="style-pack-swatch__accent" style="background:#6b7280"></div><div class="style-pack-swatch__accent2" style="background:#9ca3af"></div></div>
            <span>Light</span>
          </button>
          <button class="style-pack-btn" data-pack="sunset">
            <div class="style-pack-swatch__bg" style="background:#1a0a14"><div class="style-pack-swatch__accent" style="background:#f97316"></div><div class="style-pack-swatch__accent2" style="background:#ec4899"></div></div>
            <span>Sunset</span>
          </button>
          <button class="style-pack-btn" data-pack="corporate">
            <div class="style-pack-swatch__bg" style="background:#0f172a"><div class="style-pack-swatch__accent" style="background:#3b82f6"></div><div class="style-pack-swatch__accent2" style="background:#60a5fa"></div></div>
            <span>Corporate</span>
          </button>
          <button class="style-pack-btn" data-pack="creative">
            <div class="style-pack-swatch__bg" style="background:#1a0a20"><div class="style-pack-swatch__accent" style="background:#e879f9"></div><div class="style-pack-swatch__accent2" style="background:#f472b6"></div></div>
            <span>Creative</span>
          </button>
        </div>
        </div>
      </section>

      <section class="panel panel--collapsible">
        <h3 class="panel__title panel__title--toggle" data-collapsed="false">Templates <svg class="panel__chevron" width="10" height="6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 1l4 4 4-4"/></svg></h3>
        <div class="panel__body">
        <div class="template-scroll">
        <div class="template-grid">
          <button class="template-btn active" data-template="minimal"><div class="tmpl tmpl--minimal"></div><span>Minimal</span></button>
          <button class="template-btn" data-template="bold"><div class="tmpl tmpl--bold"></div><span>Bold</span></button>
          <button class="template-btn" data-template="gradient"><div class="tmpl tmpl--gradient"></div><span>Gradient</span></button>
          <button class="template-btn" data-template="split"><div class="tmpl tmpl--split"></div><span>Split</span></button>
          <button class="template-btn" data-template="editorial"><div class="tmpl tmpl--editorial"></div><span>Editorial</span></button>
          <button class="template-btn" data-template="glass"><div class="tmpl tmpl--glass"></div><span>Glass</span></button>
          <button class="template-btn" data-template="neon"><div class="tmpl tmpl--neon"></div><span>Neon</span></button>
          <button class="template-btn" data-template="promo"><div class="tmpl tmpl--promo"></div><span>Promo</span></button>
          <button class="template-btn" data-template="quote"><div class="tmpl tmpl--quote"></div><span>Citation</span></button>
          <button class="template-btn" data-template="duotone"><div class="tmpl tmpl--duotone"></div><span>Duotone</span></button>
          <button class="template-btn" data-template="geometric"><div class="tmpl tmpl--geometric"></div><span>Geometric</span></button>
          <button class="template-btn" data-template="typewriter"><div class="tmpl tmpl--typewriter"></div><span>Typewriter</span></button>
          <button class="template-btn" data-template="blobs"><div class="tmpl tmpl--blobs"></div><span>Blobs</span></button>
          <button class="template-btn" data-template="cards"><div class="tmpl tmpl--cards"></div><span>Cards</span></button>
          <button class="template-btn" data-template="grid-pattern"><div class="tmpl tmpl--grid-pattern"></div><span>Grid</span></button>
          <button class="template-btn" data-template="magazine"><div class="tmpl tmpl--magazine"></div><span>Magazine</span></button>
          <button class="template-btn" data-template="poster"><div class="tmpl tmpl--poster"></div><span>Poster</span></button>
          <button class="template-btn" data-template="layered"><div class="tmpl tmpl--layered"></div><span>Layered</span></button>
        </div>
        </div>
        </div>
      </section>
    </div>

    <!-- TAB: Texte -->
    <div class="tab-content" data-tab-content="text">
      <section class="panel">
        <div class="field field--check field--toggle-free">
          <input type="checkbox" id="opt-free-layout">
          <label for="opt-free-layout">Disposition libre</label>
          <span class="hint" style="font-size:11px;color:var(--text-muted);margin-left:4px">(deplacer les textes)</span>
        </div>
      </section>
      <section class="panel panel--collapsible">
        <h3 class="panel__title panel__title--toggle" data-collapsed="false">Contenu <svg class="panel__chevron" width="10" height="6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 1l4 4 4-4"/></svg></h3>
        <div class="panel__body">
        <div class="field">
          <label>Titre principal</label>
          <input type="text" id="input-headline" value="Studio digital" placeholder="Titre...">
        </div>
        <div class="field">
          <div class="field-label-row">
            <label>Sous-titre</label>
            <label class="mini-toggle"><input type="checkbox" id="toggle-subline" checked><span class="mini-toggle__dot"></span></label>
          </div>
          <input type="text" id="input-subline" value="Marseille" placeholder="Sous-titre...">
        </div>
        <div class="field" id="subline-style-field">
          <label>Style sous-titre</label>
          <div class="subline-style-btns" id="subline-style-btns">
            <button class="sline-btn active" data-sline="text" title="Texte">Aa</button>
            <button class="sline-btn" data-sline="badge" title="Badge"><span class="sline-prev sline-prev--badge">A</span></button>
            <button class="sline-btn" data-sline="pill" title="Pilule"><span class="sline-prev sline-prev--pill">A</span></button>
            <button class="sline-btn" data-sline="separator" title="Separateur"><span class="sline-prev sline-prev--separator">—</span></button>
          </div>
        </div>
        <div class="field">
          <div class="field-label-row">
            <label>Corps de texte</label>
            <label class="mini-toggle"><input type="checkbox" id="toggle-body" checked><span class="mini-toggle__dot"></span></label>
          </div>
          <textarea id="input-body" rows="3" placeholder="Description...">Sites, apps et outils sur-mesure pour artisans, commercants et independants.</textarea>
        </div>
        <div class="field">
          <div class="field-label-row">
            <label>CTA / Bas de page</label>
            <label class="mini-toggle"><input type="checkbox" id="toggle-cta" checked><span class="mini-toggle__dot"></span></label>
          </div>
          <input type="text" id="input-cta" value="latraverse.studio" placeholder="CTA ou URL...">
        </div>
        <div class="field">
          <label>Style du CTA</label>
          <div class="cta-style-btns" id="cta-style-btns">
            <button class="cta-style-btn active" data-style="text" title="Texte simple">Aa</button>
            <button class="cta-style-btn" data-style="filled" title="Bouton plein">
              <span class="cta-style-btn__filled"></span>
            </button>
            <button class="cta-style-btn" data-style="outline" title="Bouton contour">
              <span class="cta-style-btn__outline"></span>
            </button>
            <button class="cta-style-btn" data-style="pill" title="Pilule">
              <span class="cta-style-btn__pill"></span>
            </button>
          </div>
          <div id="cta-shape-controls" style="display:none; margin-top:8px">
            <div class="field-row">
              <div class="field field--half">
                <label>Rayon <span id="cta-radius-val">6</span>px</label>
                <input type="range" id="cta-radius" min="0" max="30" value="6" step="1">
              </div>
              <div class="field field--half">
                <label>Pad V <span id="cta-pad-v-val">0.5</span>em</label>
                <input type="range" id="cta-pad-v" min="2" max="15" value="5" step="1">
              </div>
            </div>
            <div class="field">
              <label>Pad H <span id="cta-pad-h-val">1.2</span>em</label>
              <input type="range" id="cta-pad-h" min="5" max="30" value="12" step="1">
            </div>
          </div>
          <div class="field" style="margin-top:8px">
