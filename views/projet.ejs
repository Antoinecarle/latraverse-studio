<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= client.name %> &mdash; La Traverse</title>
<meta name="description" content="<%= (client.description || '').substring(0, 160) %>">
<link rel="icon" type="image/png" href="/images/logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,400;1,500;1,700&family=DM+Serif+Display:ital@0;1&family=Instrument+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/landing.css?v=<%= Date.now() %>">
<style>
/* ===== PROJET DETAIL PAGE ===== */
.projet-page {
  background: var(--color-bg);
  min-height: 100vh;
}

/* Back nav */
.projet-back {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 20px clamp(20px, 5vw, 80px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(250, 250, 248, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
  transition: box-shadow 0.3s ease;
}
.projet-back.is-scrolled {
  box-shadow: 0 1px 12px rgba(0,0,0,0.06);
}
.projet-back__link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-secondary);
  text-decoration: none;
  transition: color 0.2s ease;
}
.projet-back__link:hover {
  color: var(--color-accent);
}
.projet-back__brand {
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text);
  text-decoration: none;
}
.projet-back__brand span {
  color: var(--color-text-tertiary);
  font-weight: 400;
}

/* Hero */
.projet-hero {
  padding-top: 120px;
  padding-bottom: 60px;
  padding-left: clamp(20px, 5vw, 80px);
  padding-right: clamp(20px, 5vw, 80px);
  max-width: var(--full-max);
  margin: 0 auto;
}
.projet-hero__eyebrow {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}
.projet-hero__eyebrow-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
}
.projet-hero__title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(36px, 6vw, 72px);
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: var(--color-text);
  margin-bottom: 20px;
}
.projet-hero__industry {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  padding: 6px 14px;
  border: 1px solid var(--color-border);
  border-radius: 2px;
  display: inline-block;
}

/* Screenshot showcase */
.projet-screenshot {
  max-width: var(--full-max);
  margin: 0 auto 60px;
  padding: 0 clamp(20px, 5vw, 80px);
}
.projet-screenshot__frame {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  background: var(--color-bg-dark);
  border: 1px solid var(--color-border);
  box-shadow: 0 20px 60px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);
}
.projet-screenshot__bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 14px 20px;
  background: var(--color-bg-dark);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.projet-screenshot__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
}
.projet-screenshot__dot:first-child { background: #ff5f56; }
.projet-screenshot__dot:nth-child(2) { background: #ffbd2e; }
.projet-screenshot__dot:nth-child(3) { background: #27c93f; }
.projet-screenshot__url {
  font-family: var(--font-mono);
  font-size: 11px;
  color: rgba(255,255,255,0.4);
  margin-left: 12px;
}
.projet-screenshot__img {
  width: 100%;
  display: block;
}
.projet-screenshot__placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 300px;
  color: rgba(255,255,255,0.2);
  font-family: var(--font-mono);
  font-size: 14px;
}

/* Content grid */
.projet-content {
  max-width: var(--full-max);
  margin: 0 auto;
  padding: 0 clamp(20px, 5vw, 80px) 80px;
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 60px;
}
.projet-content__main {}

.projet-content__desc-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  margin-bottom: 16px;
}
.projet-content__desc {
  font-family: var(--font-serif-body);
  font-size: 18px;
  line-height: 1.8;
  color: var(--color-text);
  margin-bottom: 40px;
}

/* Services tags */
.projet-services {
  margin-bottom: 40px;
}
.projet-services__label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  margin-bottom: 16px;
}
.projet-services__list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.projet-services__tag {
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 500;
  padding: 8px 18px;
  border-radius: 999px;
  background: var(--color-bg-alt);
  color: var(--color-text);
  border: 1px solid var(--color-border);
  transition: all 0.2s ease;
}
.projet-services__tag:hover {
  background: var(--color-accent);
  color: #fff;
  border-color: var(--color-accent);
}

/* Testimonial */
.projet-testimonial {
  padding: 36px;
  background: var(--color-bg-alt);
  border-radius: 8px;
  border-left: 3px solid var(--color-accent);
  margin-bottom: 40px;
}
.projet-testimonial__text {
  font-family: var(--font-serif-body);
  font-style: italic;
  font-size: 16px;
  line-height: 1.75;
  color: var(--color-text);
  margin: 0 0 24px 0;
}
.projet-testimonial__author {
  display: flex;
  align-items: center;
  gap: 14px;
  padding-top: 20px;
  border-top: 1px solid var(--color-border);
}
.projet-testimonial__photo {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--color-border);
  flex-shrink: 0;
}
.projet-testimonial__info {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}
.projet-testimonial__name {
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text);
  font-style: normal;
}
.projet-testimonial__linkedin {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-sans);
  font-size: 12px;
  font-style: normal;
  color: #0a66c2;
  text-decoration: none;
  transition: opacity 0.2s;
}
.projet-testimonial__linkedin:hover {
  opacity: 0.75;
  text-decoration: underline;
}
.projet-testimonial__linkedin svg {
  flex-shrink: 0;
}
.projet-testimonial__verified {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 10px;
  font-style: normal;
  letter-spacing: 0.05em;
  color: #0a66c2;
  background: rgba(10, 102, 194, 0.08);
  padding: 3px 8px;
  border-radius: 4px;
  margin-left: 4px;
}

/* Sidebar */
.projet-sidebar {}
.projet-sidebar__card {
  padding: 36px;
  background: var(--color-bg-cream);
  border-radius: 8px;
  position: sticky;
  top: 100px;
}
.projet-sidebar__label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  margin-bottom: 20px;
}
.projet-sidebar__item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 24px;
}
.projet-sidebar__item:last-child {
  margin-bottom: 0;
}
.projet-sidebar__icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: rgba(196, 98, 42, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--color-accent);
}
.projet-sidebar__item-label {
  font-family: var(--font-sans);
  font-size: 12px;
  color: var(--color-text-tertiary);
  margin-bottom: 4px;
}
.projet-sidebar__item-value {
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text);
}
.projet-sidebar__item-value a {
  color: var(--color-accent);
  text-decoration: none;
}
.projet-sidebar__item-value a:hover {
  text-decoration: underline;
}
.projet-sidebar__cta {
  display: block;
  text-align: center;
  margin-top: 28px;
  padding: 14px 28px;
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  background: var(--color-accent);
  border: none;
  border-radius: 6px;
  text-decoration: none;
  transition: all 0.2s ease;
}
.projet-sidebar__cta:hover {
  background: var(--color-accent-hover);
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(196, 98, 42, 0.25);
}

/* Color bar at the top */
.projet-color-bar {
  height: 4px;
  width: 100%;
}

/* Other projects */
.projet-others {
  max-width: var(--full-max);
  margin: 0 auto;
  padding: 80px clamp(20px, 5vw, 80px);
  border-top: 1px solid var(--color-border);
}
.projet-others__title {
  font-family: var(--font-serif);
  font-size: clamp(24px, 3vw, 32px);
  color: var(--color-text);
  margin-bottom: 32px;
}
.projet-others__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}
.projet-others__card {
  display: block;
  padding: 28px;
  background: var(--color-bg-alt);
  border-radius: 8px;
  border: 1px solid var(--color-border);
  text-decoration: none;
  color: inherit;
  transition: all 0.3s ease;
}
.projet-others__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  border-color: var(--color-accent);
}
.projet-others__card-img {
  width: 100%;
  height: 160px;
  object-fit: cover;
  border-radius: 6px;
  margin-bottom: 16px;
  background: var(--color-bg-cream);
}
.projet-others__card-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  margin-bottom: 6px;
}
.projet-others__card-name {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 6px;
}
.projet-others__card-desc {
  font-family: var(--font-sans);
  font-size: 14px;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

/* Responsive */
@media (max-width: 768px) {
  .projet-content {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .projet-sidebar__card {
    position: static;
  }
  .projet-hero__title {
    font-size: clamp(32px, 8vw, 48px);
  }
}

/* Entrance animations */
.projet-fade {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
}
.projet-fade.is-visible {
  opacity: 1;
  transform: translateY(0);
}
.projet-fade:nth-child(2) { transition-delay: 0.08s; }
.projet-fade:nth-child(3) { transition-delay: 0.16s; }
.projet-fade:nth-child(4) { transition-delay: 0.24s; }
</style>
</head>
<body class="projet-page">

<!-- Color bar -->
<div class="projet-color-bar" style="background: <%= client.color || '#c4622a' %>"></div>

<!-- Nav -->
<nav class="projet-back" id="projetNav">
  <a href="/#realisations" class="projet-back__link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Retour aux r&eacute;alisations
  </a>
  <a href="/" class="projet-back__brand">Traverse <span>Studio</span></a>
</nav>

<main>
  <!-- Hero -->
  <section class="projet-hero projet-fade">
    <div class="projet-hero__eyebrow">
      <span class="projet-hero__eyebrow-dot"></span>
      Projet client
    </div>
    <h1 class="projet-hero__title"><%= client.name %></h1>
    <% if (client.industry) { %>
      <span class="projet-hero__industry"><%= client.industry %></span>
    <% } %>
  </section>

  <!-- Screenshot -->
  <section class="projet-screenshot projet-fade">
    <div class="projet-screenshot__frame">
      <div class="projet-screenshot__bar">
        <span class="projet-screenshot__dot"></span>
        <span class="projet-screenshot__dot"></span>
        <span class="projet-screenshot__dot"></span>
        <% if (client.url) { %>
          <span class="projet-screenshot__url"><%= client.url.replace(/^https?:\/\//, '') %></span>
        <% } %>
      </div>
      <% if (client.screenshot_url) { %>
        <img src="<%= client.screenshot_url %>" alt="Screenshot du site <%= client.name %>" class="projet-screenshot__img">
      <% } else { %>
        <div class="projet-screenshot__placeholder">Aper&ccedil;u bient&ocirc;t disponible</div>
      <% } %>
    </div>
  </section>

  <!-- Content -->
  <section class="projet-content">
    <div class="projet-content__main">
      <% if (client.description) { %>
        <div class="projet-fade">
          <div class="projet-content__desc-label">Le projet</div>
          <p class="projet-content__desc"><%= client.description %></p>
        </div>
      <% } %>

      <% if (client.services_provided) { %>
        <div class="projet-services projet-fade">
          <div class="projet-services__label">Services fournis</div>
          <div class="projet-services__list">
            <% client.services_provided.split(',').forEach(function(s) { %>
              <span class="projet-services__tag"><%= s.trim() %></span>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if (client.testimonial) { %>
        <div class="projet-testimonial projet-fade">
          <p class="projet-testimonial__text">&laquo;&nbsp;<%= client.testimonial %>&nbsp;&raquo;</p>
          <% if (client.testimonial_name || client.testimonial_linkedin) { %>
            <div class="projet-testimonial__author">
              <% if (client.testimonial_photo) { %>
                <img src="<%= client.testimonial_photo %>" alt="<%= client.testimonial_name || 'Auteur' %>" class="projet-testimonial__photo">
              <% } %>
              <div class="projet-testimonial__info">
                <% if (client.testimonial_name) { %>
                  <span class="projet-testimonial__name"><%= client.testimonial_name %></span>
                <% } %>
                <% if (client.testimonial_linkedin) { %>
                  <a href="<%= client.testimonial_linkedin %>" target="_blank" rel="noopener" class="projet-testimonial__linkedin">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#0a66c2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    Voir le profil LinkedIn
                    <span class="projet-testimonial__verified">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                      Verifie
                    </span>
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <aside class="projet-sidebar projet-fade">
      <div class="projet-sidebar__card">
        <div class="projet-sidebar__label">Fiche projet</div>

        <div class="projet-sidebar__item">
          <div class="projet-sidebar__icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5m-4 0h4"/></svg>
          </div>
          <div>
            <div class="projet-sidebar__item-label">Client</div>
            <div class="projet-sidebar__item-value"><%= client.name %></div>
          </div>
        </div>

        <% if (client.industry) { %>
        <div class="projet-sidebar__item">
          <div class="projet-sidebar__icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div>
            <div class="projet-sidebar__item-label">Secteur</div>
            <div class="projet-sidebar__item-value"><%= client.industry %></div>
          </div>
        </div>
        <% } %>

        <% if (client.url) { %>
        <div class="projet-sidebar__item">
          <div class="projet-sidebar__icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z"/><path d="M3.6 9h16.8M3.6 15h16.8"/><path d="M12 3a15.3 15.3 0 0 1 4 9 15.3 15.3 0 0 1-4 9 15.3 15.3 0 0 1-4-9 15.3 15.3 0 0 1 4-9z"/></svg>
          </div>
          <div>
            <div class="projet-sidebar__item-label">Site web</div>
            <div class="projet-sidebar__item-value"><a href="<%= client.url %>" target="_blank" rel="noopener"><%= client.url.replace(/^https?:\/\//, '') %></a></div>
          </div>
        </div>
        <% } %>

        <div class="projet-sidebar__item">
          <div class="projet-sidebar__icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div>
            <div class="projet-sidebar__item-label">R&eacute;alis&eacute; par</div>
            <div class="projet-sidebar__item-value">Adrien &amp; Antoine</div>
          </div>
        </div>

        <a href="/#contact" class="projet-sidebar__cta">
          Un projet similaire&nbsp;? Parlons-en
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-left:6px"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </aside>
  </section>

  <!-- Other projects -->
  <% if (others && others.length > 0) { %>
  <section class="projet-others projet-fade">
    <h2 class="projet-others__title">Autres r&eacute;alisations</h2>
    <div class="projet-others__grid">
      <% others.forEach(function(o) { %>
        <a href="/projet/<%= o.id %>" class="projet-others__card">
          <% if (o.screenshot_url) { %>
            <img src="<%= o.screenshot_url %>" alt="<%= o.name %>" class="projet-others__card-img" loading="lazy">
          <% } %>
          <div class="projet-others__card-tag"><%= o.industry || 'Digital' %></div>
          <div class="projet-others__card-name"><%= o.name %></div>
          <div class="projet-others__card-desc"><%= (o.description || '').substring(0, 80) %><%= (o.description || '').length > 80 ? '...' : '' %></div>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>

<!-- Footer -->
<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <span class="footer__brand">La Traverse</span>
      <span class="footer__copy">&copy; 2026 &mdash; Studio digital &middot; Marseille</span>
    </div>
    <div class="footer__right">
      <a href="/mentions-legales" class="footer__link">Mentions l&eacute;gales</a>
      <a href="/confidentialite" class="footer__link">Politique de confidentialit&eacute;</a>
      <a href="/" class="footer__link">Accueil</a>
    </div>
  </div>
</footer>

<script>
(function() {
  'use strict';

  // Nav scroll shadow
  var nav = document.getElementById('projetNav');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 20) {
      nav.classList.add('is-scrolled');
    } else {
      nav.classList.remove('is-scrolled');
    }
  }, { passive: true });

  // Entrance animations
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion) {
    document.querySelectorAll('.projet-fade').forEach(function(el) {
      el.classList.add('is-visible');
    });
    return;
  }

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.projet-fade').forEach(function(el) {
    observer.observe(el);
  });
})();
</script>
</body>
