<script>
  let currentStep = 1;
  const totalSteps = 7;

  function goToStep(n) {
    // Validation step 1
    if (n > 1 && currentStep === 1) {
      const name = document.getElementById('client_name').value.trim();
      const email = document.getElementById('client_email').value.trim();
      if (!name || !email) {
        alert('Merci de remplir au moins votre nom et votre email.');
        return;
      }
    }

    // Validation step 2
    if (n > 2 && currentStep === 2) {
      const profile = document.querySelector('input[name="profile"]:checked');
      const scenario = document.querySelector('input[name="scenario"]:checked');
      if (!profile || !scenario) {
        alert('Merci de choisir un profil et un type de projet.');
        return;
      }
    }

    currentStep = n;

    // Update steps visibility
    document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
    const target = document.querySelector(`.step[data-step="${n}"]`);
    if (target) target.classList.add('active');

    // Update progress
    const steps = document.querySelectorAll('.progress-step');
    steps.forEach((s, i) => {
      s.classList.remove('done', 'active');
      if (i < n - 1) s.classList.add('done');
      if (i === n - 1) s.classList.add('active');
    });

    document.getElementById('progressLabel').textContent = `Etape ${n} sur ${totalSteps}`;

    // Scroll to top
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function selectProfile(el, value) {
    document.querySelectorAll('.profile-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    el.querySelector('input').checked = true;

    // Toggle body class for conditional tech sections
    document.body.className = '';
    document.body.classList.add('profile-' + value);
  }

  function selectScenario(el, value) {
    document.querySelectorAll('.scenario-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    el.querySelector('input').checked = true;
  }

  function collectData() {
    const profile = document.querySelector('input[name="profile"]:checked');
    const scenario = document.querySelector('input[name="scenario"]:checked');

    // Collect all textarea answers
    const answers = {};
    document.querySelectorAll('textarea[id^="q_"]').forEach(ta => {
      if (ta.value.trim()) answers[ta.id] = ta.value.trim();
    });

    // Collect document checklist
    const documents = {};
    document.querySelectorAll('.checklist-item input[type="checkbox"]').forEach(cb => {
      documents[cb.id] = cb.checked;
    });

    // Collect accesses
    const accesses = {};
    document.querySelectorAll('.access-field input').forEach(inp => {
      if (inp.value.trim()) accesses[inp.id] = inp.value.trim();
    });

    return {
      client_name: document.getElementById('client_name').value.trim(),
      client_email: document.getElementById('client_email').value.trim(),
      client_phone: document.getElementById('client_phone').value.trim(),
      client_website: document.getElementById('client_website').value.trim(),
      client_company: document.getElementById('client_company').value.trim(),
      profile: profile ? profile.value : null,
      scenario: scenario ? scenario.value : null,
      answers,
      documents,
      accesses,
      human_notes: null,
    };
  }

  async function submitDiagnostic() {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';

    try {
      const data = collectData();

      const res = await fetch('/api/diagnostic', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Erreur serveur');
      }

      // Show confirmation
      document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
      document.querySelector('.step[data-step="done"]').classList.add('active');
      document.getElementById('progressLabel').textContent = 'Termine !';
      document.querySelectorAll('.progress-step').forEach(s => s.classList.add('done'));

    } catch (err) {
      alert('Erreur lors de l\'envoi : ' + err.message);
      btn.disabled = false;
      btn.textContent = 'Envoyer le diagnostic';
    }
  }
</script>

</body>
</html>
