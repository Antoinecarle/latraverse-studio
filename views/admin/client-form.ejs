<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= client ? 'Editer' : 'Nouveau' %> client — La Traverse Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <nav class="admin-nav">
    <a href="/" class="admin-logo">
      <span class="logo-icon">&#9971;</span>
      Traverse <span class="logo-sub">Admin</span>
    </a>
    <div class="admin-nav-right">
      <a href="/admin" class="nav-link">Clients</a>
      <a href="/" class="nav-link" target="_blank">Voir le site</a>
    </div>
  </nav>

  <main class="admin-main">
    <div class="admin-header">
      <div>
        <a href="/admin" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Retour
        </a>
        <h1 class="admin-title"><%= client ? 'Editer' : 'Nouveau' %> client</h1>
      </div>
    </div>

    <!-- AI Auto-fill section -->
    <div class="ai-section">
      <div class="ai-header">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c4622a" stroke-width="1.5">
          <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
          <path d="M18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/>
        </svg>
        <div>
          <h3>Remplissage automatique par IA</h3>
          <p>Collez le lien du site, cochez ce qu'on a realise, et l'IA genere la fiche projet.</p>
        </div>
      </div>
      <div class="ai-input-row">
        <input type="url" id="aiUrl" placeholder="https://example.com" class="input-field ai-url-input">
        <button type="button" id="aiBtn" class="btn-ai" onclick="analyzeWithAI()">
          <span class="ai-btn-text">Analyser avec l'IA</span>
          <span class="ai-btn-loading" style="display:none">
            <svg class="spinner" width="18" height="18" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="30 70" stroke-linecap="round"/></svg>
            Analyse en cours...
          </span>
        </button>
      </div>
      <!-- Services checkboxes -->
      <div class="ai-services-section">
        <div class="ai-services-label">
          <span class="ai-services-title">Ce qu'on a realise pour ce client</span>
          <span class="ai-services-hint">Plus tu coches, plus la description sera riche. Si rien n'est coche, l'IA devinera.</span>
        </div>
        <div class="ai-services-grid">
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="site-vitrine" checked>
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Site web</span>
              <span class="ai-check-desc">Site vitrine, landing page, multi-pages</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="design">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Identite visuelle</span>
              <span class="ai-check-desc">Logo, charte graphique, direction artistique</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="seo">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Referencement</span>
              <span class="ai-check-desc">SEO local, Google Business, visibilite</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="reservation">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Reservation en ligne</span>
              <span class="ai-check-desc">Prise de RDV, calendrier, disponibilites</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="ecommerce">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Boutique en ligne</span>
              <span class="ai-check-desc">E-commerce, paiement, gestion produits</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="app-mobile">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Application mobile</span>
              <span class="ai-check-desc">App iOS/Android, notifications</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="dashboard">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Espace de gestion</span>
              <span class="ai-check-desc">Dashboard, tableau de bord, back-office</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="outil-gestion">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Outil metier</span>
              <span class="ai-check-desc">Devis, planning, facturation, CRM</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="ia">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Outils intelligents</span>
              <span class="ai-check-desc">Automatisations, recommandations, assistant</span>
            </span>
          </label>
          <label class="ai-service-check">
            <input type="checkbox" name="ai_service" value="maintenance">
            <span class="ai-check-box"></span>
            <span class="ai-check-content">
              <span class="ai-check-name">Maintenance & suivi</span>
              <span class="ai-check-desc">Support continu, evolutions, accompagnement</span>
            </span>
          </label>
        </div>
        <div class="ai-services-summary" id="aiServicesSummary">
          <span class="ai-summary-count" id="aiSummaryCount">1</span> prestation selectionnee
        </div>
      </div>

      <div id="aiError" class="ai-error" style="display:none"></div>
      <div id="aiSuccess" class="ai-success" style="display:none">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <span id="aiSuccessText"></span>
      </div>
    </div>

    <form method="POST" action="<%= client ? '/admin/clients/' + client.id : '/admin/clients' %>" class="client-form">
      <div class="form-grid">
        <div class="form-group">
          <label for="name">Nom du client *</label>
          <input type="text" id="name" name="name" required value="<%= client ? client.name : '' %>" class="input-field" placeholder="Salon Elodie">
        </div>
        <div class="form-group">
          <label for="url">URL du site</label>
          <input type="url" id="url" name="url" value="<%= client ? (client.url || '') : '' %>" class="input-field" placeholder="https://salon-elodie.fr">
        </div>
        <div class="form-group">
          <label for="industry">Secteur d'activite</label>
          <select id="industry" name="industry" class="input-field">
            <option value="">Choisir...</option>
            <% ['Commerce', 'Artisanat', 'Sante', 'Liberal', 'Sport', 'Tech', 'Restauration', 'Mode', 'Immobilier', 'Education', 'Autre'].forEach(i => { %>
              <option value="<%= i %>" <%= (client && client.industry === i) ? 'selected' : '' %>><%= i %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="color">Couleur</label>
          <div class="color-row">
            <input type="color" id="color" name="color" value="<%= client ? (client.color || '#c4622a') : '#c4622a' %>" class="color-picker">
            <span class="color-hex" id="colorHex"><%= client ? (client.color || '#c4622a') : '#c4622a' %></span>
          </div>
        </div>
      </div>

      <div class="form-group full">
        <label for="description">Description du projet</label>
        <textarea id="description" name="description" rows="4" class="input-field" placeholder="Nous avons accompagne ce client dans sa traversee numerique..."><%= client ? (client.description || '') : '' %></textarea>
      </div>

      <div class="form-group full">
        <label for="services_provided">Services fournis</label>
        <input type="text" id="services_provided" name="services_provided" value="<%= client ? (client.services_provided || '') : '' %>" class="input-field" placeholder="Site vitrine, SEO, Design responsive, Reservation en ligne">
        <span class="form-hint">Separez les services par des virgules</span>
      </div>

      <div class="form-group full">
        <label for="testimonial">Temoignage client</label>
        <textarea id="testimonial" name="testimonial" rows="3" class="input-field" placeholder="La Traverse a parfaitement compris notre vision..."><%= client ? (client.testimonial || '') : '' %></textarea>
      </div>

      <!-- Testimonial author info -->
      <div class="testimonial-author-section">
        <div class="testimonial-author-header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Auteur du temoignage
        </div>

        <!-- Photo preview + upload -->
        <div class="testimonial-photo-row">
          <div class="testimonial-photo-preview" id="authorPhotoPreview">
            <% if (client && client.testimonial_photo) { %>
              <img id="authorPhotoImg" src="<%= client.testimonial_photo %>" alt="Photo auteur">
            <% } else { %>
              <img id="authorPhotoImg" src="" alt="Photo auteur" style="display:none">
              <svg class="testimonial-photo-placeholder" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <% } %>
          </div>
          <div class="testimonial-photo-actions">
            <button type="button" class="btn-upload-photo" onclick="document.getElementById('photoFileInput').click()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Photo
            </button>
            <input type="file" id="photoFileInput" accept="image/png,image/jpeg,image/webp" style="display:none">
            <input type="hidden" id="testimonial_photo" name="testimonial_photo" value="<%= client ? (client.testimonial_photo || '') : '' %>">
          </div>
        </div>

        <div class="form-grid" style="margin-bottom:0">
          <div class="form-group">
            <label for="testimonial_name">Nom et fonction</label>
            <input type="text" id="testimonial_name" name="testimonial_name" value="<%= client ? (client.testimonial_name || '') : '' %>" class="input-field" placeholder="Claire Martin, Co-fondatrice">
          </div>
          <div class="form-group">
            <label for="testimonial_linkedin">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:inline;vertical-align:-2px;margin-right:4px;opacity:0.5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              Profil LinkedIn
            </label>
            <input type="url" id="testimonial_linkedin" name="testimonial_linkedin" value="<%= client ? (client.testimonial_linkedin || '') : '' %>" class="input-field" placeholder="https://linkedin.com/in/claire-martin">
          </div>
        </div>
      </div>

      <!-- Screenshot section -->
      <div class="screenshot-section">
        <label class="screenshot-label">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          Screenshot du projet
        </label>
        <input type="hidden" id="screenshot_url" name="screenshot_url" value="<%= client ? (client.screenshot_url || '') : '' %>">

        <div class="screenshot-content">
          <!-- Preview -->
          <div class="screenshot-preview" id="screenshotPreview" style="<%= (client && client.screenshot_url) ? '' : 'display:none' %>">
            <img id="screenshotImg" src="<%= (client && client.screenshot_url) ? client.screenshot_url : '' %>" alt="Screenshot">
            <button type="button" class="screenshot-remove" onclick="removeScreenshot()" title="Supprimer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>

          <!-- Upload zone (shown when no preview) -->
          <div class="screenshot-upload-zone" id="uploadZone" style="<%= (client && client.screenshot_url) ? 'display:none' : '' %>">
            <div class="upload-dropzone" id="dropzone">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.4"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              <p>Glissez une image ici ou <span class="upload-browse">parcourir</span></p>
              <span class="upload-hint">PNG, JPG, WebP — max 10 Mo</span>
              <input type="file" id="fileInput" accept="image/png,image/jpeg,image/webp,image/gif" style="display:none">
            </div>

            <div class="upload-divider">
              <span>ou</span>
            </div>

            <button type="button" class="btn-capture" id="captureBtn" onclick="captureScreenshot()">
              <span class="capture-btn-text">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                Capturer depuis l'URL du site
              </span>
              <span class="capture-btn-loading" style="display:none">
                <svg class="spinner" width="16" height="16" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="30 70" stroke-linecap="round"/></svg>
                Capture en cours...
              </span>
            </button>
            <span class="upload-hint" style="text-align:center">Utilise l'URL du champ "URL du site" ci-dessus</span>
          </div>
        </div>

        <div id="screenshotError" class="screenshot-error" style="display:none"></div>
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label for="logo_url">URL logo</label>
          <input type="url" id="logo_url" name="logo_url" value="<%= client ? (client.logo_url || '') : '' %>" class="input-field" placeholder="https://...">
        </div>
        <div class="form-group">
          <label for="display_order">Ordre d'affichage</label>
          <input type="number" id="display_order" name="display_order" value="<%= client ? (client.display_order || 0) : 0 %>" class="input-field" min="0">
        </div>
        <div class="form-group checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" name="is_featured" <%= (client && client.is_featured) ? 'checked' : '' %>>
            <span class="checkmark"></span>
            Afficher en vedette sur le site
          </label>
        </div>
      </div>

      <div class="form-actions">
        <a href="/admin" class="btn-secondary">Annuler</a>
        <button type="submit" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <%= client ? 'Mettre a jour' : 'Creer le client' %>
        </button>
      </div>
    </form>
  </main>

  <script>
    // Color picker sync
    const colorPicker = document.getElementById('color');
    const colorHex = document.getElementById('colorHex');
    colorPicker.addEventListener('input', () => {
      colorHex.textContent = colorPicker.value;
    });

    // ===== AUTHOR PHOTO UPLOAD =====
    const photoFileInput = document.getElementById('photoFileInput');
    const authorPhotoImg = document.getElementById('authorPhotoImg');
    const authorPhotoPreview = document.getElementById('authorPhotoPreview');
    const testimonialPhotoInput = document.getElementById('testimonial_photo');

    photoFileInput.addEventListener('change', async () => {
      if (!photoFileInput.files.length) return;
      const file = photoFileInput.files[0];
      if (file.size > 5 * 1024 * 1024) { alert('Photo trop lourde (max 5 Mo)'); return; }

      const formData = new FormData();
      formData.append('screenshot', file);
      try {
        const res = await fetch('/api/upload-screenshot', { method: 'POST', body: formData });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error);
        testimonialPhotoInput.value = data.url;
        authorPhotoImg.src = data.url;
        authorPhotoImg.style.display = 'block';
        const placeholder = authorPhotoPreview.querySelector('.testimonial-photo-placeholder');
        if (placeholder) placeholder.style.display = 'none';
      } catch (err) {
        alert('Erreur upload photo: ' + err.message);
      }
    });

    // ===== SCREENSHOT UPLOAD & CAPTURE =====
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('fileInput');
    const uploadZone = document.getElementById('uploadZone');
    const previewDiv = document.getElementById('screenshotPreview');
    const previewImg = document.getElementById('screenshotImg');
    const hiddenInput = document.getElementById('screenshot_url');
    const errorDiv2 = document.getElementById('screenshotError');

    // Click on dropzone -> open file picker
    dropzone.addEventListener('click', () => fileInput.click());

    // Drag and drop
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('dragover');
    });
    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('dragover');
    });
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('dragover');
      if (e.dataTransfer.files.length) uploadFile(e.dataTransfer.files[0]);
    });

    // File input change
    fileInput.addEventListener('change', () => {
      if (fileInput.files.length) uploadFile(fileInput.files[0]);
    });

    async function uploadFile(file) {
      errorDiv2.style.display = 'none';
      if (file.size > 10 * 1024 * 1024) {
        errorDiv2.textContent = 'Fichier trop volumineux (max 10 Mo)';
        errorDiv2.style.display = 'block';
        return;
      }

      const formData = new FormData();
      formData.append('screenshot', file);

      try {
        dropzone.classList.add('uploading');
        const res = await fetch('/api/upload-screenshot', { method: 'POST', body: formData });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur upload');
        setScreenshot(data.url);
      } catch (err) {
        errorDiv2.textContent = err.message;
        errorDiv2.style.display = 'block';
      } finally {
        dropzone.classList.remove('uploading');
      }
    }

    async function captureScreenshot() {
      const siteUrl = document.getElementById('url').value.trim();
      if (!siteUrl) {
        errorDiv2.textContent = 'Remplissez d\'abord le champ "URL du site" ci-dessus';
        errorDiv2.style.display = 'block';
        return;
      }

      errorDiv2.style.display = 'none';
      const btn = document.getElementById('captureBtn');
      const btnText = btn.querySelector('.capture-btn-text');
      const btnLoading = btn.querySelector('.capture-btn-loading');

      btn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline-flex';

      try {
        const res = await fetch('/api/capture-screenshot', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: siteUrl }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur capture');
        setScreenshot(data.url);
      } catch (err) {
        errorDiv2.textContent = err.message;
        errorDiv2.style.display = 'block';
      } finally {
        btn.disabled = false;
        btnText.style.display = 'inline-flex';
        btnLoading.style.display = 'none';
      }
    }

    function setScreenshot(url) {
      hiddenInput.value = url;
      previewImg.src = url;
      previewDiv.style.display = 'block';
      uploadZone.style.display = 'none';
    }

    function removeScreenshot() {
      hiddenInput.value = '';
      previewImg.src = '';
      previewDiv.style.display = 'none';
      uploadZone.style.display = 'block';
    }

    // ===== AI SERVICES CHECKBOXES =====
    const serviceChecks = document.querySelectorAll('input[name="ai_service"]');
    const summaryCount = document.getElementById('aiSummaryCount');
    const summaryDiv = document.getElementById('aiServicesSummary');

    function updateServicesSummary() {
      const checked = document.querySelectorAll('input[name="ai_service"]:checked');
      const count = checked.length;
      summaryCount.textContent = count;
      summaryDiv.innerHTML = count === 0
        ? '<span class="ai-summary-auto">L\'IA devinera les services a partir du site</span>'
        : `<span class="ai-summary-count">${count}</span> prestation${count > 1 ? 's' : ''} selectionnee${count > 1 ? 's' : ''}${count >= 6 ? ' <span class="ai-summary-badge">Accompagnement complet</span>' : ''}`;
    }

    serviceChecks.forEach(cb => cb.addEventListener('change', updateServicesSummary));
    updateServicesSummary();

    // ===== AI AUTO-FILL =====
    async function analyzeWithAI() {
      const url = document.getElementById('aiUrl').value.trim();
      if (!url) { alert('Entrez une URL'); return; }

      // Collect selected services
      const checkedServices = Array.from(document.querySelectorAll('input[name="ai_service"]:checked')).map(cb => cb.value);

      const btn = document.getElementById('aiBtn');
      const btnText = btn.querySelector('.ai-btn-text');
      const btnLoading = btn.querySelector('.ai-btn-loading');
      const errorDiv = document.getElementById('aiError');
      const successDiv = document.getElementById('aiSuccess');
      const successText = document.getElementById('aiSuccessText');

      btn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline-flex';
      errorDiv.style.display = 'none';
      successDiv.style.display = 'none';

      try {
        const res = await fetch('/api/ai/analyze-url', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url, services: checkedServices }),
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || 'Erreur API');
        }

        // Fill the form
        if (data.name) document.getElementById('name').value = data.name;
        if (data.industry) {
          const select = document.getElementById('industry');
          for (const opt of select.options) {
            if (opt.value.toLowerCase() === data.industry.toLowerCase()) {
              select.value = opt.value;
              break;
            }
          }
          if (!select.value && data.industry) {
            for (const opt of select.options) {
              if (data.industry.toLowerCase().includes(opt.value.toLowerCase()) ||
                  opt.value.toLowerCase().includes(data.industry.toLowerCase())) {
                select.value = opt.value;
                break;
              }
            }
          }
        }
        if (data.description) document.getElementById('description').value = data.description;
        if (data.services_provided) document.getElementById('services_provided').value = data.services_provided;
        if (data.testimonial) document.getElementById('testimonial').value = data.testimonial;
        if (data.testimonial_name) document.getElementById('testimonial_name').value = data.testimonial_name;
        if (data.color) {
          document.getElementById('color').value = data.color;
          document.getElementById('colorHex').textContent = data.color;
        }

        // Also fill the URL field
        document.getElementById('url').value = url;

        // Auto-capture screenshot if none set
        if (!hiddenInput.value) {
          captureScreenshot();
        }

        // Success feedback
        const techInfo = data._techDetected && data._techDetected.length > 0
          ? ` | Detecte sur le site : ${data._techDetected.join(', ')}`
          : '';
        successText.textContent = `Fiche generee${data._scraped ? ' (site analyse en profondeur)' : ''}${techInfo}`;
        successDiv.style.display = 'flex';

        // Visual feedback on filled fields
        document.querySelectorAll('.input-field').forEach(el => {
          if (el.value) {
            el.classList.add('ai-filled');
            setTimeout(() => el.classList.remove('ai-filled'), 2000);
          }
        });

      } catch (err) {
        errorDiv.textContent = err.message;
        errorDiv.style.display = 'block';
      } finally {
        btn.disabled = false;
        btnText.style.display = 'inline';
        btnLoading.style.display = 'none';
      }
    }
  </script>
</body>
</html>
