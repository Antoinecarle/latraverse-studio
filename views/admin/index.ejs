<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin — La Traverse</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Instrument+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root { --copper: #c4622a; --copper-light: #d4722e; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Instrument Sans', sans-serif; background: #0f0d0a; color: #f0e8dc; min-height: 100vh; }

  /* Nav */
  .admin-nav {
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
  }
  .admin-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 20px;
    color: #f0e8dc;
    text-decoration: none;
  }
  .admin-logo span {
    color: var(--copper);
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-left: 8px;
  }
  .admin-back { color: rgba(240,232,220,0.5); text-decoration: none; font-size: 13px; transition: color 0.3s; }
  .admin-back:hover { color: var(--copper); }

  .admin-container { max-width: 1100px; margin: 0 auto; padding: 32px; }

  /* Tabs */
  .admin-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 28px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .admin-tab {
    padding: 12px 24px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(240,232,220,0.4);
    cursor: pointer;
    border: none;
    background: none;
    border-bottom: 2px solid transparent;
    transition: all 0.3s;
    font-family: 'Instrument Sans', sans-serif;
  }
  .admin-tab:hover { color: rgba(240,232,220,0.7); }
  .admin-tab.active { color: var(--copper); border-bottom-color: var(--copper); }

  .admin-panel { display: none; }
  .admin-panel.active { display: block; }

  /* Section header */
  .admin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .admin-title { font-family: 'DM Serif Display', serif; font-size: 24px; font-weight: 400; }
  .admin-count { font-family: 'Space Mono', monospace; font-size: 11px; color: rgba(240,232,220,0.35); letter-spacing: 1px; margin-top: 4px; }

  /* Buttons */
  .admin-btn {
    padding: 10px 20px;
    background: var(--copper);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.3s;
    font-family: 'Instrument Sans', sans-serif;
  }
  .admin-btn:hover { background: var(--copper-light); transform: translateY(-1px); }
  .admin-btn-sm { padding: 6px 14px; font-size: 11px; border-radius: 6px; }
  .admin-btn-outline { background: transparent; border: 1px solid rgba(255,255,255,0.1); color: rgba(240,232,220,0.7); }
  .admin-btn-outline:hover { border-color: var(--copper); color: var(--copper); background: transparent; }
  .admin-btn-danger { background: rgba(139,32,32,0.6); }
  .admin-btn-danger:hover { background: #8b2020; }

  /* Table */
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    background: rgba(255,255,255,0.015);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .admin-table th {
    text-align: left;
    padding: 12px 16px;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(240,232,220,0.3);
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    font-weight: 400;
  }
  .admin-table td {
    padding: 14px 16px;
    font-size: 13px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    vertical-align: middle;
  }
  .admin-table tr:last-child td { border-bottom: none; }
  .admin-table tr:hover td { background: rgba(255,255,255,0.01); }

  /* Lead styles */
  .lead-email { font-weight: 600; color: #f0e8dc; }
  .lead-parcours {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: capitalize;
  }
  .lead-parcours-vitrine { background: rgba(139,115,85,0.2); color: #c4a882; }
  .lead-parcours-application { background: rgba(106,90,205,0.2); color: #9b8ee0; }
  .lead-parcours-outil { background: rgba(240,232,220,0.08); color: rgba(240,232,220,0.7); }
  .lead-parcours-ia { background: rgba(196,98,42,0.2); color: var(--copper-light); }
  .lead-date { font-size: 11px; color: rgba(240,232,220,0.3); }
  .lead-metier { font-size: 12px; color: rgba(240,232,220,0.45); }
  .lead-selections { font-size: 11px; color: rgba(240,232,220,0.35); max-width: 280px; line-height: 1.5; }
  .lead-sub { font-size: 11px; color: rgba(240,232,220,0.4); }

  /* Client card styles */
  .clients-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
  .client-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 20px;
    transition: all 0.3s;
  }
  .client-card:hover { border-color: rgba(255,255,255,0.1); }
  .client-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; padding-left: 12px; border-left: 3px solid var(--copper); }
  .client-name { font-family: 'DM Serif Display', serif; font-size: 16px; }
  .client-industry { font-size: 11px; color: rgba(240,232,220,0.4); display: block; margin-top: 2px; }
  .badge-featured { font-size: 10px; background: rgba(46,139,87,0.15); color: #5dbb89; padding: 3px 8px; border-radius: 8px; font-weight: 600; }
  .client-desc { font-size: 12px; color: rgba(240,232,220,0.5); line-height: 1.5; margin-bottom: 10px; }
  .client-services { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 10px; }
  .service-tag { font-size: 10px; padding: 2px 8px; border-radius: 6px; background: rgba(196,98,42,0.1); color: var(--copper-light); }
  .client-url { font-size: 11px; color: var(--copper); text-decoration: none; display: block; margin-bottom: 12px; }
  .client-url:hover { text-decoration: underline; }
  .client-actions { display: flex; gap: 8px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.04); }
  .client-actions form { display: inline; }

  /* Empty state */
  .admin-empty { text-align: center; padding: 60px 20px; color: rgba(240,232,220,0.25); font-size: 14px; font-style: italic; }

  .admin-actions { display: flex; gap: 6px; align-items: center; }
  .admin-actions form { display: inline; }

  @media (max-width: 768px) {
    .admin-container { padding: 16px; }
    .admin-nav { padding: 14px 16px; }
    .admin-table { font-size: 12px; }
    .admin-table th, .admin-table td { padding: 10px 8px; }
    .lead-selections { display: none; }
    .clients-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<nav class="admin-nav">
  <a href="/admin" class="admin-logo">Traverse <span>Admin</span></a>
  <a href="/" class="admin-back" target="_blank">Voir le site</a>
</nav>

<div class="admin-container">

  <div class="admin-tabs">
    <button class="admin-tab active" data-tab="diagnostics">Diagnostics (<%= diagnostics.length %>)</button>
    <button class="admin-tab" data-tab="leads">Leads (<%= leads.length %>)</button>
    <button class="admin-tab" data-tab="clients">Clients (<%= clients.length %>)</button>
  </div>

  <!-- ===== DIAGNOSTICS PANEL ===== -->
  <div class="admin-panel active" id="panel-diagnostics">
    <div class="admin-header">
      <div>
        <h2 class="admin-title">Diagnostics Clients</h2>
        <div class="admin-count"><%= diagnostics.length %> diagnostic<%= diagnostics.length > 1 ? 's' : '' %></div>
      </div>
      <a href="/diagnostic" class="admin-btn" target="_blank">Lien formulaire</a>
    </div>

    <% if (diagnostics.length === 0) { %>
      <div class="admin-empty">Aucun diagnostic pour le moment. Envoyez le lien /diagnostic a vos clients.</div>
    <% } else { %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Client</th>
            <th>Entreprise</th>
            <th>Profil</th>
            <th>Scenario</th>
            <th>Statut</th>
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% diagnostics.forEach(function(d) { %>
            <%
              const profileLabels = { vierge: 'Le Vierge', equipe: "L'Equipe", migrant: 'Le Migrant' };
              const scenarioLabels = { saas: 'SaaS', scratch: 'Scratch', migration: 'Migration', ecommerce: 'E-com', ia: 'IA' };
              const statusColors = { nouveau: '#6cb4ee', en_cours: '#f5a623', complete: '#3ecf8e', archive: '#666' };
            %>
            <tr>
              <td>
                <div class="lead-email"><%= d.client_name %></div>
                <div class="lead-sub"><%= d.client_email %></div>
                <% if (d.client_phone) { %><div class="lead-sub"><%= d.client_phone %></div><% } %>
              </td>
              <td><span class="lead-metier"><%= d.client_company || '-' %></span></td>
              <td><span class="lead-parcours" style="background:rgba(196,98,42,0.15);color:#d4722e"><%= profileLabels[d.profile] || d.profile || '-' %></span></td>
              <td><span class="lead-parcours" style="background:rgba(108,180,238,0.15);color:#6cb4ee"><%= scenarioLabels[d.scenario] || d.scenario || '-' %></span></td>
              <td><span class="lead-parcours" style="background:<%= statusColors[d.status] || '#666' %>22;color:<%= statusColors[d.status] || '#666' %>"><%= d.status %></span></td>
              <td><span class="lead-date"><%= new Date(d.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span></td>
              <td>
                <div class="admin-actions">
                  <a href="/admin/diagnostic/<%= d.id %>" class="admin-btn admin-btn-sm admin-btn-outline">Voir</a>
                  <form method="POST" action="/admin/diagnostic/<%= d.id %>/delete" onsubmit="return confirm('Supprimer ce diagnostic ?')">
                    <button type="submit" class="admin-btn admin-btn-sm admin-btn-danger">X</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <!-- ===== LEADS PANEL ===== -->
  <div class="admin-panel" id="panel-leads">
    <div class="admin-header">
      <div>
        <h2 class="admin-title">Prospects Studio</h2>
        <div class="admin-count"><%= leads.length %> lead<%= leads.length > 1 ? 's' : '' %></div>
      </div>
    </div>

    <% if (leads.length === 0) { %>
      <div class="admin-empty">Aucun lead pour le moment. Les prospects du studio apparaitront ici.</div>
    <% } else { %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Contact</th>
            <th>Metier</th>
            <th>Parcours</th>
            <th>Selections</th>
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% leads.forEach(function(lead) { %>
            <% const sel = typeof lead.selections === 'string' ? JSON.parse(lead.selections) : (lead.selections || {}); %>
            <% const allSel = [...(sel.step1 || []), ...(sel.step2 || [])]; %>
            <tr>
              <td>
                <div class="lead-email"><%= lead.email %></div>
                <% if (lead.name) { %><div class="lead-sub"><%= lead.name %></div><% } %>
                <% if (lead.phone) { %><div class="lead-sub"><%= lead.phone %></div><% } %>
              </td>
              <td><span class="lead-metier"><%= lead.metier || '-' %></span></td>
              <td><span class="lead-parcours lead-parcours-<%= lead.parcours %>"><%= lead.parcours %></span></td>
              <td><span class="lead-selections"><%= allSel.length > 0 ? allSel.join(', ') : '-' %></span></td>
              <td><span class="lead-date"><%= new Date(lead.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span></td>
              <td>
                <div class="admin-actions">
                  <a href="mailto:<%= lead.email %>" class="admin-btn admin-btn-sm admin-btn-outline">Email</a>
                  <form method="POST" action="/admin/leads/<%= lead.id %>/delete" onsubmit="return confirm('Supprimer ce lead ?')">
                    <button type="submit" class="admin-btn admin-btn-sm admin-btn-danger">X</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <!-- ===== CLIENTS PANEL ===== -->
  <div class="admin-panel" id="panel-clients">
    <div class="admin-header">
      <div>
        <h2 class="admin-title">Clients / Realisations</h2>
        <div class="admin-count"><%= clients.length %> client<%= clients.length > 1 ? 's' : '' %></div>
      </div>
      <a href="/admin/clients/new" class="admin-btn">+ Nouveau client</a>
    </div>

    <% if (clients.length === 0) { %>
      <div class="admin-empty">Aucun client. Ajoutez votre premiere realisation.</div>
    <% } else { %>
      <div class="clients-grid">
        <% clients.forEach(function(client) { %>
          <div class="client-card">
            <div class="client-card-top" style="border-left-color: <%= client.color || '#c4622a' %>">
              <div>
                <h3 class="client-name"><%= client.name %></h3>
                <span class="client-industry"><%= client.industry || '-' %></span>
              </div>
              <% if (client.is_featured) { %><span class="badge-featured">Vedette</span><% } %>
            </div>
            <% if (client.description) { %><p class="client-desc"><%= client.description.substring(0, 120) %><%= client.description.length > 120 ? '...' : '' %></p><% } %>
            <% if (client.services_provided) { %>
              <div class="client-services">
                <% client.services_provided.split(',').slice(0, 3).forEach(function(s) { %><span class="service-tag"><%= s.trim() %></span><% }) %>
                <% if (client.services_provided.split(',').length > 3) { %><span class="service-tag">+<%= client.services_provided.split(',').length - 3 %></span><% } %>
              </div>
            <% } %>
            <% if (client.url) { %><a href="<%= client.url %>" class="client-url" target="_blank"><%= client.url.replace(/^https?:\/\//, '').substring(0, 35) %></a><% } %>
            <div class="client-actions">
              <a href="/admin/clients/<%= client.id %>/edit" class="admin-btn admin-btn-sm admin-btn-outline">Editer</a>
              <form method="POST" action="/admin/clients/<%= client.id %>/delete" onsubmit="return confirm('Supprimer ?')">
                <button type="submit" class="admin-btn admin-btn-sm admin-btn-danger">Suppr.</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<script>
  document.querySelectorAll('.admin-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.admin-tab').forEach(function(t) { t.classList.remove('active'); });
      document.querySelectorAll('.admin-panel').forEach(function(p) { p.classList.remove('active'); });
      tab.classList.add('active');
      document.getElementById('panel-' + tab.dataset.tab).classList.add('active');
    });
  });
</script>

</body>
</html>
