  <!-- ===== RIBBON INTERLUDE ===== -->
  <section class="ribbon-interlude" id="ribbon-interlude" aria-label="Les doutes que vous avez, on les connait.">
    <div class="ribbon-interlude__svg-wrap" aria-hidden="true">
      <svg viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path id="riCurve1" d="M-200,350 C100,200 350,450 720,300 C1090,150 1200,500 1640,350"/>
          <path id="riCurve2" d="M-300,500 C0,300 300,600 720,400 C1140,200 1300,550 1740,400"/>
          <path id="riCurve3" d="M-150,200 C200,400 500,100 720,350 C940,600 1100,250 1600,300"/>
          <path id="riCurve4" d="M-250,600 C0,450 350,250 720,350 C1090,450 1200,200 1700,250"/>
        </defs>
        <!-- Guide strokes -->
        <use href="#riCurve1" fill="none" stroke="rgba(196,98,42,0.08)" stroke-width="1" class="ri-stroke"/>
        <use href="#riCurve2" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1" class="ri-stroke"/>
        <use href="#riCurve3" fill="none" stroke="rgba(196,98,42,0.05)" stroke-width="1" class="ri-stroke"/>
        <!-- Text ribbons -->
        <text class="ri-text ri-text--1">
          <textPath id="riTP1" href="#riCurve1" startOffset="0%">combien ca va couter · est-ce que ca vaut le coup · et si ca marche pas · j'ai deja essaye tout seul · c'etait pas terrible · j'y connais rien en numerique ·</textPath>
        </text>
        <text class="ri-text ri-text--2">
          <textPath id="riTP2" href="#riCurve2" startOffset="25%">et si je me fais arnaquer · les devis ne sont jamais clairs · je veux pas un truc generique · j'ai pas confiance · c'est toujours plus cher que prevu ·</textPath>
        </text>
        <text class="ri-text ri-text--3">
          <textPath id="riTP3" href="#riCurve3" startOffset="50%">les autres ont l'air de s'en sortir · pourquoi pas moi · j'ai besoin d'aide mais de quelqu'un qui comprend mon metier ·</textPath>
        </text>
        <text class="ri-text ri-text--4">
          <textPath id="riTP4" href="#riCurve4" startOffset="75%">il doit bien y avoir quelqu'un de confiance · sans jargon · sans me prendre de haut · qui m'explique simplement ·</textPath>
        </text>
      </svg>
    </div>
    <!-- Visible doubts display -->
    <div class="ri-doubts" aria-label="Les doutes courants de nos clients">
      <div class="ri-doubt" data-delay="0">&laquo;&nbsp;Combien &ccedil;a va co&ucirc;ter&nbsp;?&nbsp;&raquo;</div>
      <div class="ri-doubt" data-delay="1">&laquo;&nbsp;Et si &ccedil;a marche pas&nbsp;?&nbsp;&raquo;</div>
      <div class="ri-doubt" data-delay="2">&laquo;&nbsp;J'y connais rien en num&eacute;rique&nbsp;&raquo;</div>
      <div class="ri-doubt" data-delay="3">&laquo;&nbsp;Et si je me fais arnaquer&nbsp;?&nbsp;&raquo;</div>
      <div class="ri-doubt" data-delay="4">&laquo;&nbsp;C'est toujours plus cher que pr&eacute;vu&nbsp;&raquo;</div>
      <div class="ri-doubt" data-delay="5">&laquo;&nbsp;J'ai pas confiance&nbsp;&raquo;</div>
      <div class="ri-doubt" data-delay="6">&laquo;&nbsp;Je veux pas un truc g&eacute;n&eacute;rique&nbsp;&raquo;</div>
      <div class="ri-doubt" data-delay="7">&laquo;&nbsp;Les devis ne sont jamais clairs&nbsp;&raquo;</div>
    </div>

    <div class="ribbon-interlude__message">
      <div class="ri-msg-label">On connait ces doutes</div>
      <h2 class="ri-msg-title">Ces questions,<br>on les entend <em>chaque semaine</em>.</h2>
      <p class="ri-msg-sub">Et c'est exactement pour ca qu'on est la.<br>Pas pour tout compliquer &mdash; pour tout clarifier.</p>
    </div>
  </section>

  <!-- ===== SECTION BREAK: Méthode ===== -->
  <div class="section-break reveal-section" aria-hidden="true">
    <div class="section-break__inner">
      <span class="section-break__label">Notre m&eacute;thode</span>
      <div class="section-break__rule"></div>
      <span class="section-break__badge">Clair &amp; sans surprise</span>
    </div>
  </div>

  <!-- ===== METHODE ===== -->
  <section class="section methode reveal-section" id="methode" data-parallax-speed="0.03">
    <div class="section__container">
      <div class="section__header">
        <span class="section__number" data-count-target="02">02</span>
        <span class="overline">La Travers&eacute;e</span>
        <h2 class="section__title">Cinq &eacute;tapes,<br>z&eacute;ro surprise</h2>
        <p class="section__subtitle">Chaque projet suit le m&ecirc;me chemin. Clair, transparent, &agrave; votre rythme.</p>
      </div>

      <div class="methode__timeline" id="methodeTimeline">
        <!-- The animated line is drawn via JS using a pseudo approach -->
        <div class="methode__timeline-line" id="methodeTimelineLine"></div>

        <div class="methode__step reveal-item">
          <div class="methode__step-number" data-count-target="01">01</div>
          <div class="methode__step-content">
            <h3 class="methode__step-title">Le Premier Caf&eacute;</h3>
            <p class="methode__step-desc">On se rencontre, on &eacute;coute votre m&eacute;tier. Gratuit, sans engagement, environ 1 heure.</p>
          </div>
        </div>

        <div class="methode__step reveal-item">
          <div class="methode__step-number" data-count-target="02">02</div>
          <div class="methode__step-content">
            <h3 class="methode__step-title">La Cartographie</h3>
            <p class="methode__step-desc">On analyse vos besoins, on trace la feuille de route. Devis transparent, d&eacute;taill&eacute;.</p>
          </div>
        </div>

        <div class="methode__step reveal-item">
          <div class="methode__step-number" data-count-target="03">03</div>
          <div class="methode__step-content">
            <h3 class="methode__step-title">La Construction</h3>
            <p class="methode__step-desc">On d&eacute;veloppe, vous validez &agrave; chaque &eacute;tape. Pas de tunnel de 3 mois sans nouvelles.</p>
          </div>
        </div>

        <div class="methode__step reveal-item">
          <div class="methode__step-number" data-count-target="04">04</div>
          <div class="methode__step-content">
            <h3 class="methode__step-title">Le Lancement</h3>
            <p class="methode__step-desc">Mise en ligne ensemble, formation incluse. Vous repartez autonome.</p>
          </div>
        </div>

        <div class="methode__step reveal-item">
          <div class="methode__step-number" data-count-target="05">05</div>
          <div class="methode__step-content">
            <h3 class="methode__step-title">La Croissance</h3>
            <p class="methode__step-desc">On reste &agrave; vos c&ocirc;t&eacute;s. Maintenance, &eacute;volutions, accompagnement durable.</p>
          </div>
        </div>

      </div>

      <!-- Progress bar -->
      <div class="methode__progress" id="methodeProgress">
        <div class="methode__progress-track">
          <div class="methode__progress-fill" id="methodeProgressFill"></div>
        </div>
        <span class="methode__progress-label">Dur&eacute;e moyenne d'un projet&nbsp;: 6 &agrave; 10 semaines, du premier caf&eacute; &agrave; la mise en ligne</span>
      </div>

    </div>
  </section>

  <!-- ===== SECTION BREAK: Réalisations ===== -->
  <div class="section-break reveal-section" aria-hidden="true">
    <div class="section-break__inner">
      <span class="section-break__label">Portfolio</span>
      <div class="section-break__rule"></div>
      <span class="section-break__badge">Nos r&eacute;alisations</span>
    </div>
  </div>

  <!-- ===== REALISATIONS ===== -->
  <section class="section realisations reveal-section" id="realisations" data-parallax-speed="0.025">
    <div class="section__container">
      <div class="section__header">
        <span class="section__number" data-count-target="03">03</span>
        <span class="overline">Ce qu'on a construit</span>
        <h2 class="section__title">Des solutions concr&egrave;tes<br>pour des m&eacute;tiers concrets</h2>
      </div>

      <div class="realisations__grid">

        <% if (typeof clients !== 'undefined' && clients.length > 0) { %>
          <% const cardStyles = ['real-card--featured real-card--cream', 'real-card--dark', 'real-card--copper', 'real-card--light']; %>
          <% clients.forEach((c, i) => { %>
            <article class="real-card <%= cardStyles[i % cardStyles.length] %> reveal-item"<% if (c.url) { %> onclick="window.open('<%= c.url %>', '_blank')" style="cursor:pointer"<% } %>>
              <span class="real-card__tag" data-typewriter-card="<%= c.industry || 'Digital' %>"><%= c.industry || 'Digital' %></span>
              <h3 class="real-card__title"><%= c.name %></h3>
              <p class="real-card__desc"><%= c.description || (c.services_provided ? c.services_provided.split(',').join(' + ') : 'Projet digital sur-mesure.') %></p>
              <span class="real-card__type"><%= c.services_provided ? c.services_provided.split(',')[0].trim() : 'Parcours Digital' %></span>
            </article>
          <% }) %>
        <% } else { %>
          <article class="real-card real-card--featured real-card--cream reveal-item">
            <span class="real-card__tag" data-typewriter-card="Coiffure">Coiffure</span>
            <h3 class="real-card__title">Salon &Eacute;lodie</h3>
            <p class="real-card__desc">Site vitrine + r&eacute;servation en ligne. Une pr&eacute;sence soign&eacute;e qui refl&egrave;te son savoir-faire, avec un syst&egrave;me de prise de rendez-vous int&eacute;gr&eacute;.</p>
            <span class="real-card__type">Parcours Vitrine</span>
          </article>

          <article class="real-card real-card--dark reveal-item reveal-item--scale">
            <span class="real-card__tag" data-typewriter-card="Architecture">Architecture</span>
            <h3 class="real-card__title">Studio Archi+</h3>
            <p class="real-card__desc">Portfolio 3D + espace client. Un &eacute;crin visuel pour des projets d'exception.</p>
            <span class="real-card__type">Parcours Vitrine</span>
          </article>

          <article class="real-card real-card--copper reveal-item reveal-item--tilt">
            <span class="real-card__tag" data-typewriter-card="Artisan BTP">Artisan BTP</span>
            <h3 class="real-card__title">Martin &amp; Fils</h3>
            <p class="real-card__desc">Outil de devis + gestion chantier. Fini le papier, place &agrave; l'efficacit&eacute;.</p>
            <span class="real-card__type">Parcours Outil</span>
          </article>

          <article class="real-card real-card--light reveal-item reveal-item--deep">
            <span class="real-card__tag" data-typewriter-card="Sport & Coaching">Sport &amp; Coaching</span>
            <h3 class="real-card__title">Coach Maxime</h3>
            <p class="real-card__desc">App suivi + prise de rendez-vous. Un outil complet pour fid&eacute;liser ses clients.</p>
            <span class="real-card__type">Parcours Application</span>
          </article>
        <% } %>

      </div>
    </div>
  </section>

  <!-- ===== EQUIPE ===== -->
  <section class="section equipe reveal-section" id="equipe" data-parallax-speed="0.035">
    <div class="section__container">
      <div class="section__header">
        <span class="section__number" data-count-target="04">04</span>
        <span class="overline">Qui sommes-nous</span>
        <h2 class="section__title">Deux d&eacute;veloppeurs,<br>une vision</h2>
        <p class="section__subtitle">Pas de sous-traitance. Pas d'interm&eacute;diaire. On fait le travail nous-m&ecirc;mes.</p>
      </div>

      <div class="equipe__grid">

        <div class="equipe__member reveal-item">
          <div class="equipe__photo-wrap">
            <img src="/images/portrait-adrien.jpeg" alt="Adrien, co-fondateur de La Traverse" class="equipe__photo equipe__photo--animate" loading="lazy">
          </div>
          <div class="equipe__info">
            <h3 class="equipe__name equipe__name--animate">Adrien</h3>
            <span class="equipe__role equipe__role--typein">Co-fondateur &amp; D&eacute;veloppeur fullstack</span>
            <p class="equipe__bio">
              Il construit des sites et des applications avec le soin d'un artisan. Chaque ligne de code est pens&eacute;e pour durer, chaque interface pour simplifier la vie de ceux qui l'utilisent.
            </p>
          </div>
        </div>

        <div class="equipe__member reveal-item">
          <div class="equipe__photo-wrap">
            <img src="/images/portrait-antoine.jpeg" alt="Antoine, co-fondateur de La Traverse" class="equipe__photo equipe__photo--animate" loading="lazy">
          </div>
          <div class="equipe__info">
            <h3 class="equipe__name equipe__name--animate">Antoine</h3>
            <span class="equipe__role equipe__role--typein">Co-fondateur &amp; D&eacute;veloppeur IA</span>
            <p class="equipe__bio">
              Strat&eacute;gie, intelligence artificielle, automatisation. Son objectif&nbsp;: que la technologie se fasse oublier pour que votre m&eacute;tier, lui, brille.
            </p>
          </div>
        </div>

      </div>

      <!-- Equipe quote: words split by JS for stagger -->
      <div class="equipe__quote reveal-item" id="equipeQuote">
        <div class="equipe__quote-rule"></div>
        <blockquote class="equipe__quote-text">
          Partenaires, pas prestataires.
        </blockquote>
        <div class="equipe__quote-rule"></div>
      </div>
    </div>
  </section>

  <!-- ===== VALEURS ===== -->
  <section class="section valeurs reveal-section" id="valeurs" data-parallax-speed="0.04">
    <div class="section__container">
      <div class="valeurs__grid">

        <div class="valeur reveal-item reveal-item--from-left">
          <h3 class="valeur__title">Z&eacute;ro jargon</h3>
          <p class="valeur__desc">On parle m&eacute;tier, pas code. Chaque d&eacute;cision vous est expliqu&eacute;e clairement.</p>
        </div>

        <div class="valeur reveal-item reveal-item--scale">
          <h3 class="valeur__title">&Agrave; votre rythme</h3>
          <p class="valeur__desc">On avance au rythme qui vous convient. Pas de tendances inutiles, pas de pression.</p>
