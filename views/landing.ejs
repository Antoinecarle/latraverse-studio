  <!-- ===== MARQUEE ===== -->
  <div class="marquee-wrap" aria-hidden="true">
    <div class="marquee-track" id="marqueeTrack">
      <span class="marquee__inner">
        <span class="marquee__dot"></span>Site vitrine<span class="marquee__dot"></span>R&eacute;servation en ligne<span class="marquee__dot"></span>Boutique e-commerce<span class="marquee__dot"></span>Application mobile<span class="marquee__dot"></span>Outil de gestion<span class="marquee__dot"></span>R&eacute;f&eacute;rencement local<span class="marquee__dot"></span>Design sur-mesure<span class="marquee__dot"></span>Formation incluse<span class="marquee__dot"></span>Accompagnement durable&nbsp;&nbsp;
      </span>
      <span class="marquee__inner" aria-hidden="true">
        <span class="marquee__dot"></span>Site vitrine<span class="marquee__dot"></span>R&eacute;servation en ligne<span class="marquee__dot"></span>Boutique e-commerce<span class="marquee__dot"></span>Application mobile<span class="marquee__dot"></span>Outil de gestion<span class="marquee__dot"></span>R&eacute;f&eacute;rencement local<span class="marquee__dot"></span>Design sur-mesure<span class="marquee__dot"></span>Formation incluse<span class="marquee__dot"></span>Accompagnement durable&nbsp;&nbsp;
      </span>
    </div>
  </div>

  <!-- ===== SECTION BREAK: Contact ===== -->
  <div class="section-break reveal-section" aria-hidden="true">
    <div class="section-break__inner">
      <span class="section-break__label">On commence&nbsp;?</span>
      <div class="section-break__rule"></div>
      <span class="section-break__badge">Cr&eacute;neaux dispo</span>
    </div>
  </div>

  <!-- ===== CONTACT ===== -->
  <section class="section contact reveal-section" id="contact" data-parallax-speed="0.02">
    <div class="section__container">
      <div class="section__header">
        <span class="section__number" data-count-target="05">05</span>
        <span class="overline">On commence&nbsp;?</span>
        <h2 class="section__title">Le premier caf&eacute;<br>est offert</h2>
        <p class="section__subtitle">30 minutes, z&eacute;ro engagement. On discute de votre projet et on voit si on fait la route ensemble.</p>
      </div>

      <div class="contact__grid">

        <form class="contact__form" id="contactForm" action="/contact" method="POST">
          <div class="form__group">
            <label for="contact-name" class="form__label">Nom</label>
            <input type="text" id="contact-name" name="name" class="form__input" placeholder="Votre nom" required>
          </div>
          <div class="form__group">
            <label for="contact-email" class="form__label">Email</label>
            <input type="email" id="contact-email" name="email" class="form__input" placeholder="votre@email.com" required>
          </div>
          <div class="form__group">
            <label for="contact-metier" class="form__label">Votre m&eacute;tier</label>
            <input type="text" id="contact-metier" name="metier" class="form__input" placeholder="Boulanger, architecte, coach...">
          </div>
          <div class="form__group">
            <label for="contact-message" class="form__label">Message</label>
            <textarea id="contact-message" name="message" class="form__input form__textarea" placeholder="Parlez-nous de votre projet..." rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn--filled btn--full">Envoyer <span class="btn__arrow">&rarr;</span></button>
          <div class="form__success" id="formSuccess">
            <p>Merci&nbsp;! Votre message a bien &eacute;t&eacute; envoy&eacute;. On vous recontacte tr&egrave;s vite.</p>
          </div>
        </form>

        <div class="contact__info">
          <div class="availability-tag">
            <span class="availability-tag__dot"></span>
            <span class="availability-tag__text">Disponibles pour nouveaux projets</span>
          </div>
          <div class="contact__info-block">
            <span class="overline">Email</span>
            <a href="mailto:hello@latraverse.studio" class="contact__info-link">hello@latraverse.studio</a>
          </div>
          <div class="contact__info-block">
            <span class="overline">T&eacute;l&eacute;phone</span>
            <a href="tel:+33601350754" class="contact__info-link">06 01 35 07 54</a>
          </div>
          <div class="contact__info-block">
            <span class="overline">Adresse</span>
            <p class="contact__info-text">Marseille, France</p>
          </div>
          <a href="https://tidycal.com/m202e9l/30-minute-meeting" target="_blank" rel="noopener" class="btn btn--filled contact__booking-btn">
            R&eacute;server un cr&eacute;neau <span class="btn__arrow">&rarr;</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== FINAL CARD ===== -->
  <section class="section final-section reveal-section" id="rdv">
    <div class="section__container">
      <div class="ob-final-card">
        <div class="ob-final-team">
          <img src="/images/portrait-adrien.jpeg" alt="Adrien" class="ob-final-avatar">
          <img src="/images/portrait-antoine.jpeg" alt="Antoine" class="ob-final-avatar">
        </div>
        <p class="ob-final-text">Adrien &amp; Antoine<br><span>Studio digital &middot; Marseille</span></p>
        <a href="https://tidycal.com/m202e9l/30-minute-meeting" target="_blank" rel="noopener" class="ob-cta-primary ob-final-btn">
          R&eacute;server un cr&eacute;neau
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
        </a>
        <div class="ob-final-contact">
          <a href="mailto:hello@latraverse.studio">hello@latraverse.studio</a>
          <span class="ob-final-separator">&middot;</span>
          <a href="tel:+33601350754">06 01 35 07 54</a>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- ===== FOOTER ===== -->
<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <span class="footer__brand">La Traverse</span>
      <span class="footer__copy">&copy; 2026 &mdash; Studio digital &middot; Marseille</span>
    </div>
    <div class="footer__right">
      <a href="/mentions-legales" class="footer__link">Mentions l&eacute;gales</a>
      <a href="/confidentialite" class="footer__link">Politique de confidentialit&eacute;</a>
