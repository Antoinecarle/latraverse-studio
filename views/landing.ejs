  <!-- ===== REALISATIONS — Onyx Dark Showcase ===== -->
  <section class="onyx-showcase reveal-section" id="realisations">
    <!-- Decorative radial glow -->
    <div class="onyx-showcase__glow" aria-hidden="true"></div>
    <!-- Noise texture overlay -->
    <div class="onyx-showcase__noise" aria-hidden="true"></div>

    <div class="onyx-showcase__container">
      <header class="onyx-showcase__header">
        <span class="onyx-showcase__overline">Ce qu'on a construit</span>
        <h2 class="onyx-showcase__title">Des solutions concr&egrave;tes<br>pour des m&eacute;tiers concrets</h2>
      </header>

      <% if (typeof clients !== 'undefined' && clients.length > 0) { %>
        <%
          // Adaptive span patterns based on number of clients
          var len = clients.length;
          var spanPatterns;
          if (len <= 2) {
            spanPatterns = ['2x1', '2x1'];
          } else if (len === 3) {
            spanPatterns = ['2x1', '1x1', '1x1'];
          } else if (len === 4) {
            spanPatterns = ['2x1', '2x1', '1x1', '1x1'];
          } else if (len === 5) {
            spanPatterns = ['2x1', '1x1', '1x1', '1x1', '1x1'];
          } else {
            spanPatterns = ['2x1', '1x1', '1x1', '2x1', '1x1', '1x1', '2x1', '2x1'];
          }
        %>
        <div class="onyx-showcase__grid" data-count="<%= len %>">
          <% clients.forEach((c, i) => { %>
            <%
              var color = c.color || '#c4622a';
              var span = spanPatterns[i % spanPatterns.length];
            %>
            <a href="/projet/<%= c.id %>"
               class="onyx-card reveal-item"
               data-span="<%= span %>"
               data-color="<%= color %>"
               style="--card-accent: <%= color %>;">

              <% if (c.screenshot_url) { %>
                <div class="onyx-card__img">
                  <img src="<%= c.screenshot_url %>" alt="Aper&ccedil;u du projet <%= c.name %>" loading="lazy">
                  <div class="onyx-card__img-overlay">
                    <span class="onyx-card__view">Voir le projet
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                  </div>
                </div>
              <% } else { %>
                <div class="onyx-card__img onyx-card__img--empty">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
              <% } %>

              <div class="onyx-card__body">
                <div class="onyx-card__top">
                  <h3 class="onyx-card__name"><%= c.name %></h3>
                  <span class="onyx-card__industry"><%= c.industry || 'Digital' %></span>
                </div>
                <p class="onyx-card__desc"><%= (c.description || '').substring(0, 140) %><%= (c.description || '').length > 140 ? '...' : '' %></p>
                <div class="onyx-card__services">
                  <% if (c.services_provided) { %>
                    <% c.services_provided.split(',').slice(0, 3).forEach(function(s) { %>
                      <span class="onyx-card__service-tag"><%= s.trim() %></span>
                    <% }) %>
                    <% if (c.services_provided.split(',').length > 3) { %>
                      <span class="onyx-card__service-tag onyx-card__service-tag--more">+<%= c.services_provided.split(',').length - 3 %></span>
                    <% } %>
                  <% } %>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="onyx-showcase__grid">
          <div class="onyx-card onyx-card--empty reveal-item" data-span="2x1">
            <div class="onyx-card__body" style="text-align:center; padding: 60px 40px;">
              <div style="margin-bottom: 24px;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c4622a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <h3 class="onyx-card__name" style="margin-bottom:16px;">Nos premiers projets sont en cours</h3>
              <p class="onyx-card__desc" style="max-width:480px; margin:0 auto 28px;">On vient de lancer le studio. &Ecirc;tre parmi nos premiers clients, c'est b&eacute;n&eacute;ficier d'une attention maximale et de tarifs de lancement.</p>
              <div class="onyx-showcase__early-perks">
                <span class="onyx-showcase__perk">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4622a" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>
                  Suivi personnalis&eacute;
                </span>
                <span class="onyx-showcase__perk">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4622a" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>
                  Tarifs pr&eacute;f&eacute;rentiels
                </span>
                <span class="onyx-showcase__perk">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4622a" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>
                  Disponibilit&eacute; imm&eacute;diate
                </span>
              </div>
              <a href="https://tidycal.com/m202e9l/30-minute-meeting" target="_blank" rel="noopener" class="onyx-showcase__cta">Devenir un des premiers <span style="margin-left:6px;">&rarr;</span></a>
            </div>
          </div>
        </div>
      <% } %>

    </div>
  </section>

